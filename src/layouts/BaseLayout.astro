---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  article?: { author: string; datePublished: string; dateModified: string; tags?: string[] };
  breadcrumb?: Array<{ name: string; url: string }>;
  schema?: object | object[];
  noindex?: boolean;
  hreflang?: Array<{ lang: string; url: string }>;
  lcpImageSrcset?: string;
  lcpImageSizes?: string;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO {...props} />
    {props.lcpImageSrcset && (
      <link rel="preload" as="image" imagesrcset={props.lcpImageSrcset} imagesizes={props.lcpImageSizes ?? '100vw'} fetchpriority="high" />
    )}
    <style is:inline>
      /* --- CRITICAL FCP/LCP CSS INLINED --- */
      :root {
        --color-navy: #0F2138;
        --color-accent: #C44B36;
        --color-surface: #FAFAFA;
        --font-serif: "Playfair Display", serif;
        --font-sans: "Inter", system-ui, sans-serif;
        --z-sticky: 100;
        --space-4: 1rem;
        --space-6: 1.5rem;
        --radius-full: 9999px;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      body {
        font-family: var(--font-sans);
        font-size: 1rem;
        line-height: 1.5;
        color: #333;
        background: var(--color-surface);
        -webkit-font-smoothing: antialiased;
      }
      .container { width: 100%; max-width: 1200px; margin-inline: auto; padding-inline: 1.5rem; }
      
      /* Header Critical */
      .header { position: sticky; top: 0; z-index: var(--z-sticky); background: rgba(15, 33, 56, 0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); height: 64px; display: flex; align-items: center; border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
      .nav { display: flex; align-items: center; justify-content: space-between; width: 100%; height: 64px; }
      .nav__logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; color: white; }
      .nav__logo-brand { font-family: var(--font-serif); font-size: 1.25rem; letter-spacing: 0.04em; }
      .nav__logo-sub { font-size: 0.75rem; color: rgba(255,255,255,0.5); font-style: italic; }
      
      /* Hero Critical */
      .hero { position: relative; min-height: 100vh; display: flex; align-items: center; color: white; overflow: hidden; background: var(--color-navy); }
      .hero__bg-full { position: absolute; inset: 0; z-index: 0; }
      .hero__bg-full img { width: 100%; height: 100%; object-fit: cover; }
      .hero__overlay-dark { position: absolute; inset: 0; background: linear-gradient(to right, rgba(15, 33, 56, 0.85) 0%, rgba(15, 33, 56, 0.4) 50%, rgba(15, 33, 56, 0.2) 100%); }
      .hero__grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 2rem; width: 100%; }
      .hero__title { font-family: var(--font-serif); font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; margin-bottom: 1.5rem; }
      
      @media (max-width: 900px) {
        .hero { min-height: auto; padding-top: 80px; padding-bottom: 2rem; }
        .hero__grid { grid-template-columns: 1fr; text-align: center; }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
