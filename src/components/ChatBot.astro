---
import { Image } from 'astro:assets';
import avatarImg from '../assets/images/chatbot-avatar.png';

// Pass the API key at build time so client JS can use it
const geminiApiKey = import.meta.env.PUBLIC_GEMINI_API_KEY || '';
---

<div id="chatbot-container" class="chatbot-container">
  <!-- Chat Toggle Button -->
  <button id="chatbot-toggle" class="chatbot-toggle" aria-label="Open chat">
    <div class="toggle-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>
    </div>
    <span class="pulse"></span>
  </button>

  <!-- Chat Window -->
  <div id="chatbot-window" class="chatbot-window hidden">
    <div class="chatbot-header">
      <div class="chatbot-info">
        <div class="avatar-container">
          <Image src={avatarImg} alt="AI Assistant" width={40} height={40} />
          <span class="status-indicator"></span>
        </div>
        <div>
          <h3 class="chatbot-name">Durian Assistant</h3>
          <p class="chatbot-status">Online • AI Powered</p>
        </div>
      </div>
      <button id="chatbot-close" class="close-btn" aria-label="Close chat">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

    <div id="chatbot-messages" class="chatbot-messages">
      <div class="message ai">
        <div class="message-content">
          Welcome! How can I assist with your European travel plans today? 🌍
        </div>
        <span class="message-time">Just now</span>
      </div>
    </div>

    <div id="typing-indicator" class="typing-indicator hidden">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <form id="chatbot-form" class="chatbot-input-area">
      <input 
        type="text" 
        id="chatbot-input" 
        placeholder="Ask me anything about Europe..." 
        autocomplete="off"
        required
      />
      <button type="submit" id="chatbot-send" aria-label="Send message">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </form>
  </div>
</div>

<!-- Inject the API key as a data attribute on the container -->
<script define:vars={{ geminiApiKey }}>
  window.__DURIAN_GEMINI_KEY = geminiApiKey;
</script>

<style>
  .chatbot-container { position: fixed; bottom: 24px; right: 24px; z-index: 1000; font-family: var(--font-sans, system-ui, sans-serif); }
  .chatbot-toggle { width: 60px; height: 60px; border-radius: 50%; background: var(--color-navy, #0F2138); color: white; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; position: relative; box-shadow: 0 8px 24px rgba(0,0,0,0.2); transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .chatbot-toggle:hover { transform: scale(1.1) translateY(-4px); }
  .pulse { position: absolute; inset: 0; border-radius: 50%; background: var(--color-navy, #0F2138); opacity: 0.6; z-index: -1; animation: pulse 2s infinite; }
  @keyframes pulse { 0% { transform: scale(1); opacity: 0.6; } 100% { transform: scale(1.5); opacity: 0; } }

  .chatbot-window { position: absolute; bottom: 80px; right: 0; width: 380px; height: 550px; background: rgba(255,255,255,0.95); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-radius: 24px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); display: flex; flex-direction: column; overflow: hidden; transform-origin: bottom right; transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease; border: 1px solid rgba(255,255,255,0.3); }
  .chatbot-window.hidden { opacity: 0; transform: scale(0.8) translateY(20px); pointer-events: none; }

  .chatbot-header { padding: 20px; background: var(--color-navy, #0F2138); color: white; display: flex; align-items: center; justify-content: space-between; }
  .chatbot-info { display: flex; align-items: center; gap: 12px; }
  .avatar-container { width: 40px; height: 40px; border-radius: 50%; overflow: hidden; background: white; padding: 2px; position: relative; }
  .avatar-container img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
  .status-indicator { position: absolute; bottom: 0; right: 0; width: 10px; height: 10px; background: #4ade80; border: 2px solid var(--color-navy, #0F2138); border-radius: 50%; }
  .chatbot-name { margin: 0; font-size: 1rem; }
  .chatbot-status { margin: 0; font-size: 0.75rem; opacity: 0.8; }
  .close-btn { background: none; border: none; color: white; cursor: pointer; padding: 4px; display: flex; align-items: center; justify-content: center; border-radius: 6px; transition: background 0.2s; }
  .close-btn:hover { background: rgba(255,255,255,0.15); }

  .chatbot-messages { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 16px; }
  .message { max-width: 85%; display: flex; flex-direction: column; gap: 4px; animation: slideUp 0.3s ease forwards; }
  @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .message.ai { align-self: flex-start; }
  .message.user { align-self: flex-end; }
  .message-content { padding: 12px 16px; border-radius: 18px; font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap; }
  .message.ai .message-content { background: white; color: #1a1a1a; border-bottom-left-radius: 4px; border: 1px solid #eee; }
  .message.ai .message-content a { color: #2563eb; text-decoration: none; font-weight: 500; border-bottom: 1px solid rgba(37,99,235,0.3); transition: color 0.2s, border-color 0.2s; }
  .message.ai .message-content a:hover { color: #1d4ed8; border-bottom-color: #1d4ed8; }
  .message.user .message-content { background: var(--color-navy, #0F2138); color: white; border-bottom-right-radius: 4px; }
  .message-time { font-size: 0.7rem; color: #999; padding: 0 4px; }
  .message.user .message-time { text-align: right; }

  .typing-indicator { padding: 12px 20px; display: flex; gap: 4px; align-items: center; }
  .typing-indicator span { width: 6px; height: 6px; background: #aaa; border-radius: 50%; animation: bounce 1.4s infinite ease-in-out both; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.16s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.32s; }
  @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }

  .chatbot-input-area { padding: 16px; background: white; border-top: 1px solid #eee; display: flex; gap: 12px; }
  .chatbot-input-area input { flex: 1; border: none; background: #f4f4f5; padding: 12px; border-radius: 12px; outline: none; font-size: 0.9rem; }
  .chatbot-input-area input:focus { box-shadow: 0 0 0 2px var(--color-navy, #0F2138); }
  .chatbot-input-area button { background: var(--color-navy, #0F2138); color: white; border: none; width: 40px; height: 40px; border-radius: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: opacity 0.2s; }
  .chatbot-input-area button:disabled { opacity: 0.5; cursor: not-allowed; }

  .hidden { display: none !important; }

  @media (max-width: 480px) {
    .chatbot-window { width: calc(100vw - 32px); right: -8px; height: 70vh; }
  }
</style>

<script>
  const SYSTEM_PROMPT = "You are the DURIAN Travel Assistant, a friendly and practical travel concierge for Durian Travel at duriantravel.com. You help users plan smoother Europe trips with strong Schengen visa guidance, realistic itineraries, and health-aware preparation. Keep responses concise and helpful, usually 2 short paragraphs max. Durian Travel now uses package-based support rather than old single-service pages. The main packages are: [The Schengen Blueprint](/services/#schengen-blueprint), [The First Journey Package](/services/#first-journey), [The Nomad Infrastructure Plan](/services/#nomad-infrastructure), [The Family Expedition Bundle](/services/#family-expedition), [The Recovery Route](/services/#recovery-route), [The Wellness Journey](/services/#wellness-journey), and [The Grand Circuit](/services/#grand-circuit). If asked about non-European destinations, politely redirect to Europe-focused help unless the question is about transit or comparative planning.\n\nIMPORTANT: When mentioning pages or services on the site, always embed a clickable markdown link on a relevant keyword or phrase. Do not display raw URLs. Use this format: [anchor text](url). Available pages include: [Services](/services), [Schengen Visa Guide](/schengen-visa-guide), [Free Visa Audit](/free-visa-audit), [Destinations](/destinations), [Blog](/blog), [Contact](/contact), [FAQ](/faq), and [About Us](/about-us). Never display a raw URL like /services. Always wrap it in a descriptive markdown link.";

  // Pollinations AI — free, no API key required
  const POLLINATIONS_URL = "https://text.pollinations.ai/openai";
  // Gemini as secondary option if key is provided
  const GEMINI_URL = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent";

  const toggleBtn = document.getElementById('chatbot-toggle');
  const closeBtn = document.getElementById('chatbot-close');
  const chatWindow = document.getElementById('chatbot-window');
  const chatForm = document.getElementById('chatbot-form');
  const chatInput = document.getElementById('chatbot-input') as HTMLInputElement;
  const chatMessages = document.getElementById('chatbot-messages');
  const typingIndicator = document.getElementById('typing-indicator');
  const sendBtn = document.getElementById('chatbot-send') as HTMLButtonElement;

  // OpenAI-compatible message format (used by Pollinations)
  let chatHistory: Array<{role: string, content: string}> = [];
  let isProcessing = false;

  toggleBtn?.addEventListener('click', () => {
    chatWindow?.classList.toggle('hidden');
    if (!chatWindow?.classList.contains('hidden')) chatInput?.focus();
  });

  closeBtn?.addEventListener('click', () => chatWindow?.classList.add('hidden'));

  chatForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isProcessing) return;
    const message = chatInput?.value.trim();
    if (!message) return;

    addMessage(message, 'user');
    chatInput.value = '';
    
    chatHistory.push({ role: 'user', content: message });

    await handleAIResponse();
  });

  function formatMessageContent(text: string, sender: string): string {
    // First, sanitize all HTML
    let safe = text.replace(/</g, '&lt;').replace(/>/g, '&gt;');

    if (sender === 'ai') {
      // Convert markdown-style links [text](url) to clickable <a> tags
      // Only allow relative links (starting with /) to keep it safe
      safe = safe.replace(/\[([^\]]+)\]\((\/[^)]+)\)/g, (_, linkText, url) => {
        return `<a href="${url}" target="_self" rel="noopener">${linkText}</a>`;
      });
    }
    return safe;
  }

  function addMessage(text: string, sender: string) {
    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${sender}`;
    const formatted = formatMessageContent(text, sender);
    messageDiv.innerHTML = `
      <div class="message-content">${formatted}</div>
      <span class="message-time">${new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
    `;
    chatMessages?.appendChild(messageDiv);
    if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  async function handleAIResponse() {
    isProcessing = true;
    if (sendBtn) sendBtn.disabled = true;
    typingIndicator?.classList.remove('hidden');
    if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;

    const geminiKey = (window as any).__DURIAN_GEMINI_KEY;
    const hasGeminiKey = geminiKey && geminiKey !== 'your_gemini_api_key_here';

    try {
      let responseText: string | null = null;

      if (hasGeminiKey) {
        // Use Gemini if a valid key is provided
        responseText = await callGeminiAPI(geminiKey);
      }

      if (!responseText) {
        // Primary: use Pollinations AI (free, no key needed)
        responseText = await callPollinationsAPI();
      }

      typingIndicator?.classList.add('hidden');

      if (responseText) {
        addMessage(responseText, 'ai');
        chatHistory.push({ role: 'assistant', content: responseText });
      } else {
        throw new Error('No response from AI');
      }
    } catch (error) {
      console.error('Chat error:', error);
      typingIndicator?.classList.add('hidden');
      // Fall back to built-in responses
      const lastMsg = chatHistory[chatHistory.length - 1]?.content || '';
      const fallbackResponse = getFallbackResponse(lastMsg);
      addMessage(fallbackResponse, 'ai');
      chatHistory.push({ role: 'assistant', content: fallbackResponse });
    } finally {
      isProcessing = false;
      if (sendBtn) sendBtn.disabled = false;
    }
  }

  async function callPollinationsAPI(): Promise<string | null> {
    try {
      const messages = [
        { role: 'system', content: SYSTEM_PROMPT },
        ...chatHistory
      ];

      const response = await fetch(POLLINATIONS_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'openai',
          messages: messages,
          temperature: 0.7,
          max_tokens: 400,
          referrer: 'duriantravel.com'
        })
      });

      if (!response.ok) {
        console.warn('Pollinations API error:', response.status);
        return null;
      }

      const data = await response.json();
      return data?.choices?.[0]?.message?.content || null;
    } catch (err) {
      console.warn('Pollinations API failed:', err);
      return null;
    }
  }

  async function callGeminiAPI(apiKey: string): Promise<string | null> {
    try {
      // Convert OpenAI format to Gemini format
      const geminiContents = chatHistory.map(msg => ({
        role: msg.role === 'assistant' ? 'model' : 'user',
        parts: [{ text: msg.content }]
      }));

      const requestBody = {
        system_instruction: { parts: [{ text: SYSTEM_PROMPT }] },
        contents: geminiContents,
        generationConfig: {
          temperature: 0.7,
          topP: 0.9,
          maxOutputTokens: 512
        }
      };

      const response = await fetch(`${GEMINI_URL}?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(requestBody)
      });

      if (!response.ok) {
        console.warn('Gemini API error:', response.status);
        return null;
      }

      const data = await response.json();
      return data?.candidates?.[0]?.content?.parts?.[0]?.text || null;
    } catch (err) {
      console.warn('Gemini API failed:', err);
      return null;
    }
  }

  function getFallbackResponse(userMessage: string): string {
    const msg = userMessage.toLowerCase();

    if (msg.includes('visa') || msg.includes('schengen')) {
      return "Great question about visas! 🛂 For Schengen applications, you will usually need a valid passport, travel insurance, proof of accommodation, financial documents, and a credible itinerary. Our [Schengen Visa Guide](/schengen-visa-guide) is the best place to start, and our [Schengen Blueprint package](/services/#schengen-blueprint) is the right fit if you want hands-on support with documents, cover letters, and route logic.";
    }
    if (msg.includes('itinerar') || msg.includes('plan') || msg.includes('trip')) {
      return "I can help with that! ✈️ If this is your first big international trip, the [First Journey package](/services/#first-journey) is usually the best match. If the route is more complex or spans multiple regions, compare it with the [Grand Circuit](/services/#grand-circuit) on our [services page](/services).";
    }
    if (msg.includes('hotel') || msg.includes('stay') || msg.includes('accommodat') || msg.includes('where to')) {
      return "We specialize in finding the most charming boutique hotels and unique stays across Europe! 🏨 From converted castles in Portugal to cozy alpine chalets in Switzerland, we'll match you with the perfect accommodation. Browse our [destinations](/destinations) and let us know your budget — we'll curate the best options for you.";
    }
    if (msg.includes('price') || msg.includes('cost') || msg.includes('how much') || msg.includes('service')) {
      return "We now organize support as packages rather than the old single-service menu. The easiest next step is to compare the packages on our [services page](/services) or start with a [Free Visa Audit](/free-visa-audit) if you want help figuring out which one fits your situation.";
    }
    if (msg.includes('health') || msg.includes('insurance') || msg.includes('medical') || msg.includes('vaccine')) {
      return "Travel health matters more than most people expect. 🏥 Our [Wellness Journey package](/services/#wellness-journey) is built for medication rules, insurance fit, vaccines, and destination-specific health prep. If you mainly need Schengen insurance and visa compliance, the [Schengen Blueprint](/services/#schengen-blueprint) may also be relevant.";
    }
    if (msg.includes('portugal') || msg.includes('lisbon') || msg.includes('porto')) {
      return "Portugal is a great choice. 🇵🇹 Lisbon, Porto, and the Algarve can work beautifully in one trip if the pacing is right. For route help, compare the [First Journey package](/services/#first-journey) and the [Grand Circuit](/services/#grand-circuit), then browse our [destinations](/destinations) for ideas.";
    }
    if (msg.includes('italy') || msg.includes('rome') || msg.includes('florence') || msg.includes('venice')) {
      return "Italy is one of the easiest places to fall in love with on a first Europe trip. 🇮🇹 Rome, Florence, and Venice can work well together if your transit days are realistic. If you want help shaping the route, start with the [First Journey package](/services/#first-journey) and browse [all our destinations](/destinations).";
    }
    if (msg.includes('france') || msg.includes('paris') || msg.includes('french')) {
      return "France gives you a lot of range, from Paris and Normandy to Provence and the Riviera. 🇫🇷 If you want help balancing city time, train legs, and budget, the [First Journey package](/services/#first-journey) is a strong place to start. You can also explore our [destinations](/destinations) for more inspiration.";
    }
    if (msg.includes('spain') || msg.includes('barcelona') || msg.includes('madrid')) {
      return "Spain can be fantastic for first-timers because the cities feel distinct without being hard to combine. 🇪🇸 If you want help building a route that actually breathes, have a look at the [First Journey package](/services/#first-journey) and browse our [destinations](/destinations).";
    }
    if (msg.includes('greece') || msg.includes('athens') || msg.includes('santorini') || msg.includes('greek')) {
      return "Greece is beautiful, especially if you want a mix of cities, islands, and slower pacing. 🇬🇷 Because ferry timing and seasonal logistics matter, the [Grand Circuit package](/services/#grand-circuit) is useful for more layered routes. You can also compare options on our [services page](/services).";
    }
    if (msg.includes('germany') || msg.includes('berlin') || msg.includes('munich') || msg.includes('bavaria')) {
      return "Germany works well when you want strong rail infrastructure and very different city personalities in one trip. 🇩🇪 If you want help structuring the route cleanly, start with the [First Journey package](/services/#first-journey) or compare it with the [Grand Circuit](/services/#grand-circuit).";
    }
    if (msg.includes('netherlands') || msg.includes('amsterdam') || msg.includes('dutch')) {
      return "The Netherlands is a strong pick if you want an easy-moving first Europe trip with great rail links. 🇳🇱 Amsterdam, Utrecht, and The Hague combine well. If you want help building the route, the [First Journey package](/services/#first-journey) is a good fit.";
    }
    if (msg.includes('switzerland') || msg.includes('zurich') || msg.includes('geneva') || msg.includes('alps')) {
      return "Switzerland is stunning, but the pacing and budget need to be handled carefully because transport and hotels add up fast. 🇨🇭 If you want help shaping the route around cost and movement, look at the [First Journey package](/services/#first-journey) or the [Grand Circuit](/services/#grand-circuit).";
    }
    if (msg.includes('croatia') || msg.includes('dubrovnik') || msg.includes('split')) {
      return "Croatia is a great route-building destination because you can mix coast, cities, and ferry or overland legs. 🇭🇷 If you want help structuring a cleaner multi-stop trip, the [Grand Circuit package](/services/#grand-circuit) is the closest fit. You can also browse our [destinations](/destinations).";
    }
    if (msg.includes('hello') || msg.includes('hi') || msg.includes('hey') || msg.includes('good')) {
      return "Hello there! 👋 I can help with [Schengen visa guidance](/schengen-visa-guide), Europe trip planning, and finding the right [travel package](/services) for your situation. Tell me where you're thinking of going or what part of the process feels confusing right now.";
    }
    if (msg.includes('thank') || msg.includes('thanks')) {
      return "You're very welcome! 😊 It's my pleasure to help. If you have any more questions about European travel, visas, or our [services](/services), don't hesitate to ask. Happy travels! ✈️🌍";
    }
    if (msg.includes('blog') || msg.includes('read') || msg.includes('article') || msg.includes('tips')) {
      return "We have a wonderful [travel blog](/blog) full of tips and inspiration! 📝 From packing guides to insider tips on the best European destinations, our blog has you covered. Head over to explore the latest articles!";
    }
    if (msg.includes('contact') || msg.includes('email') || msg.includes('phone') || msg.includes('reach')) {
      return "We'd love to hear from you! 📬 You can reach us through our [Contact page](/contact), where you'll find our email and a contact form. Our team typically responds within 24 hours. We look forward to helping you with your European travel plans!";
    }
    if (msg.includes('book') || msg.includes('reserv') || msg.includes('order')) {
      return "Ready to book? Wonderful! 🎉 Head over to our [Services page](/services) to choose the service that's right for you, or visit our [Contact page](/contact) to get in touch directly with our travel experts. We'll take it from there!";
    }

    // Default response
    return "That is a great question! 🌟 I can help with [Schengen visa guidance](/schengen-visa-guide), Europe trip planning, and choosing the right [travel package](/services). Try asking about a destination, a visa concern, or which package best fits your trip.";
  }
</script>
