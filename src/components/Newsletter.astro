---
/**
 * Newsletter signup component — powered by Brevo.
 * Props:
 *   variant: 'section' (full-width homepage block) | 'inline' (compact footer block)
 *   id:       unique form id to avoid clashes when used multiple times on a page
 */
interface Props {
  variant?: 'section' | 'inline';
  id?: string;
}
const { variant = 'section', id = 'newsletter' } = Astro.props;
---

{variant === 'section' ? (
  <!-- Full homepage newsletter section -->
  <section class="newsletter" aria-labelledby={`${id}-heading`}>
    <div class="container newsletter__inner">
      <div class="newsletter__content">
        <span class="section-label" style="color:var(--color-accent)">Stay Connected</span>
        <h2 id={`${id}-heading`} class="newsletter__title">Get Europe Travel Tips, Visa Updates &amp; Exclusive Deals</h2>
        <p class="newsletter__desc">Join 2,000+ travellers who get our bi-weekly insider tips — destination guides, visa checklists, seasonal deals and more. Unsubscribe anytime.</p>
      </div>

      <form class="newsletter__form" id={`${id}-form`} data-newsletter-form>
        <div class="newsletter__field-row">
          <div class="newsletter__input-wrap">
            <input
              type="email"
              name="EMAIL"
              required
              placeholder="Your email address"
              class="newsletter__input"
              aria-label="Email address"
              id={`${id}-email`}
            />
          </div>
          <button type="submit" class="newsletter__btn">
            <span class="newsletter__btn-text">Subscribe</span>
            <span class="newsletter__btn-loading" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke-dasharray="60" stroke-dashoffset="20"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></circle></svg>
            </span>
          </button>
        </div>
        <label class="newsletter__consent">
          <input type="checkbox" name="CONSENT" required />
          <span>I agree to receive emails from DURIAN Travel. <a href="/privacy-policy/">Privacy Policy</a></span>
        </label>
        <div class="newsletter__feedback" id={`${id}-feedback`} aria-live="polite"></div>
      </form>
    </div>
  </section>
) : (
  <!-- Compact inline newsletter (footer) -->
  <form class="footer__newsletter-form" id={`${id}-form`} data-newsletter-form>
    <div class="footer__newsletter-row">
      <input
        type="email"
        name="EMAIL"
        required
        placeholder="Email"
        class="footer__newsletter-input"
        aria-label="Email for newsletter"
        id={`${id}-email`}
      />
      <button type="submit" class="footer__newsletter-btn">
        <span class="newsletter__btn-text">Subscribe</span>
        <span class="newsletter__btn-loading" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" stroke-dasharray="60" stroke-dashoffset="20"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></circle></svg>
        </span>
      </button>
    </div>
    <label class="footer__newsletter-consent">
      <input type="checkbox" name="CONSENT" required />
      <span>I agree to receive emails. <a href="/privacy-policy/">Privacy</a></span>
    </label>
    <div class="newsletter__feedback" id={`${id}-feedback`} aria-live="polite"></div>
  </form>
)}

<!-- Shared client-side JS for all newsletter forms -->
<script>
(function() {
  /* ─── BREVO CONFIGURATION ───
     Replace this URL with your Brevo form action URL.
     To get it: Brevo Dashboard → Contacts → Forms → Create Form →
     copy the form action URL (looks like: https://xxx.sibforms.com/serve/...)
     ─────────────────────────── */
  const BREVO_FORM_URL = 'https://15cb987e.sibforms.com/serve/MUIFAOZOhVEOxVZXjAAbooSnqx_Shx1D0TJ7VqThHXBGpaAJiibkpWkVTFONEaQfYJjo7vpjpjisYLFNm0LfqQU4xLxGOUcm-7S-XiAlMFE1RtOQrNGO8SEX4bU-juKJitGkzafoMRfhcRLfUCpPV46BLpnfCk3TtCKRa_8JkE7bSr5hIvj02jmuWXjPWpC-TEMEv3pWpZemi9WfyQ==';  // ← Paste your Brevo form URL here

  document.querySelectorAll('[data-newsletter-form]').forEach(form => {
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const emailInput = form.querySelector('input[type="email"]');
      const consentInput = form.querySelector('input[name="CONSENT"]');
      const feedbackEl = form.querySelector('.newsletter__feedback');
      const btn = form.querySelector('button[type="submit"]');
      const email = emailInput?.value?.trim();

      // Validate
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showFeedback(feedbackEl, 'Please enter a valid email address.', 'error');
        return;
      }
      if (consentInput && !consentInput.checked) {
        showFeedback(feedbackEl, 'Please agree to receive emails.', 'error');
        return;
      }

      // Check if Brevo URL is configured
      if (!BREVO_FORM_URL) {
        showFeedback(feedbackEl, '✅ Thanks for subscribing! (Demo mode — connect Brevo to go live)', 'success');
        emailInput.value = '';
        if (consentInput) consentInput.checked = false;
        return;
      }

      // Submit
      btn.classList.add('is-loading');
      btn.disabled = true;

      try {
        const formData = new FormData();
        formData.append('EMAIL', email);

        const res = await fetch(BREVO_FORM_URL, {
          method: 'POST',
          body: formData,
          mode: 'no-cors',   // Brevo forms are cross-origin
        });

        // With no-cors we can't read the response, so we assume success
        showFeedback(feedbackEl, '✅ You\'re in! Check your inbox to confirm your subscription.', 'success');
        emailInput.value = '';
        if (consentInput) consentInput.checked = false;
      } catch (err) {
        showFeedback(feedbackEl, 'Something went wrong. Please try again.', 'error');
      } finally {
        btn.classList.remove('is-loading');
        btn.disabled = false;
      }
    });
  });

  function showFeedback(el, message, type) {
    if (!el) return;
    el.textContent = message;
    el.className = 'newsletter__feedback newsletter__feedback--' + type;
    el.style.display = 'block';

    // Auto-hide success after 6s
    if (type === 'success') {
      setTimeout(() => {
        el.style.display = 'none';
        el.textContent = '';
      }, 6000);
    }
  }
})();
</script>

<style>
/* ══════════════════════════════════════════
   NEWSLETTER SECTION (homepage full-width)
   ══════════════════════════════════════════ */
.newsletter {
  background: var(--color-navy);
  padding-block: var(--space-16);
  border-top: 3px solid var(--color-accent);
  position: relative;
  overflow: hidden;
}
.newsletter::before {
  content: '';
  position: absolute;
  top: -60%;
  right: -10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(196, 75, 54, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.newsletter::after {
  content: '';
  position: absolute;
  bottom: -40%;
  left: -5%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(27, 58, 92, 0.25) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.newsletter__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: center;
  position: relative;
  z-index: 1;
}
@media (max-width: 800px) {
  .newsletter__inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
    text-align: center;
  }
}

.newsletter__title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
  font-weight: 400;
  color: white;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-4);
}
.newsletter__desc {
  color: hsla(0, 0%, 100%, 0.6);
  font-size: var(--text-base);
  line-height: var(--leading-relaxed);
  max-width: 480px;
}
@media (max-width: 800px) {
  .newsletter__desc { margin-inline: auto; }
}

/* Form */
.newsletter__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}
.newsletter__field-row {
  display: flex;
  gap: 0;
}
.newsletter__input-wrap {
  flex: 1;
}
.newsletter__input {
  width: 100%;
  padding: var(--space-4) var(--space-5);
  font-size: var(--text-base);
  background: hsla(0, 0%, 100%, 0.08);
  border: 1px solid hsla(0, 0%, 100%, 0.2);
  border-right: none;
  border-radius: var(--radius-md) 0 0 var(--radius-md);
  color: white;
  outline: none;
  transition: border-color var(--transition-fast);
}
.newsletter__input::placeholder {
  color: hsla(0, 0%, 100%, 0.4);
}
.newsletter__input:focus {
  border-color: var(--color-accent);
}
.newsletter__btn {
  padding: var(--space-4) var(--space-8);
  font-size: var(--text-sm);
  font-weight: var(--font-bold);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  background: var(--color-accent);
  color: white;
  border: 1px solid var(--color-accent);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  cursor: pointer;
  transition: background var(--transition-fast);
  white-space: nowrap;
  position: relative;
}
.newsletter__btn:hover {
  background: var(--color-accent-dark);
}
.newsletter__btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

/* Loading state */
.newsletter__btn-loading {
  display: none;
}
.newsletter__btn.is-loading .newsletter__btn-text {
  visibility: hidden;
}
.newsletter__btn.is-loading .newsletter__btn-loading {
  display: flex;
  position: absolute;
  inset: 0;
  align-items: center;
  justify-content: center;
}

/* Consent checkbox */
.newsletter__consent {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  font-size: var(--text-xs);
  color: hsla(0, 0%, 100%, 0.5);
  cursor: pointer;
  line-height: var(--leading-relaxed);
}
.newsletter__consent input[type="checkbox"] {
  margin-top: 3px;
  accent-color: var(--color-accent);
  flex-shrink: 0;
}
.newsletter__consent a {
  color: hsla(0, 0%, 100%, 0.7);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.newsletter__consent a:hover {
  color: white;
}

/* Feedback messages */
.newsletter__feedback {
  display: none;
  font-size: var(--text-sm);
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-sm);
  animation: feedbackSlide 0.3s ease;
}
.newsletter__feedback--success {
  background: hsla(150, 60%, 40%, 0.15);
  color: #6ee7a0;
  border: 1px solid hsla(150, 60%, 40%, 0.3);
}
.newsletter__feedback--error {
  background: hsla(0, 70%, 50%, 0.15);
  color: #f87171;
  border: 1px solid hsla(0, 70%, 50%, 0.3);
}
@keyframes feedbackSlide {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════════════════
   FOOTER INLINE VARIANT — overrides
   ══════════════════════════════════════════ */
.footer__newsletter-form {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.footer__newsletter-row {
  display: flex;
  gap: 0;
}
.footer__newsletter-input {
  flex: 1;
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  background: hsla(0, 0%, 100%, 0.08);
  border: 1px solid hsla(0, 0%, 100%, 0.2);
  border-right: none;
  border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  color: white;
  outline: none;
  transition: border-color var(--transition-fast);
}
.footer__newsletter-input::placeholder {
  color: hsla(0, 0%, 100%, 0.35);
}
.footer__newsletter-input:focus {
  border-color: var(--color-accent);
}
.footer__newsletter-btn {
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  background: var(--color-accent);
  color: white;
  border: 1px solid var(--color-accent);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  cursor: pointer;
  transition: background var(--transition-fast);
  white-space: nowrap;
  position: relative;
}
.footer__newsletter-btn:hover {
  background: var(--color-accent-dark);
}
.footer__newsletter-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}
.footer__newsletter-btn.is-loading .newsletter__btn-text {
  visibility: hidden;
}
.footer__newsletter-btn.is-loading .newsletter__btn-loading {
  display: flex;
  position: absolute;
  inset: 0;
  align-items: center;
  justify-content: center;
}
.footer__newsletter-consent {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  font-size: 0.6875rem;
  color: hsla(0, 0%, 100%, 0.45);
  cursor: pointer;
  line-height: var(--leading-relaxed);
  margin-top: var(--space-2);
}
.footer__newsletter-consent input[type="checkbox"] {
  margin-top: 2px;
  accent-color: var(--color-accent);
  flex-shrink: 0;
}
.footer__newsletter-consent a {
  color: hsla(0, 0%, 100%, 0.6);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.footer__newsletter-consent a:hover {
  color: white;
}

@media (max-width: 600px) {
  .newsletter__field-row {
    flex-direction: column;
    gap: var(--space-3);
  }
  .newsletter__input {
    border-radius: var(--radius-md);
    border-right: 1px solid hsla(0, 0%, 100%, 0.2);
  }
  .newsletter__input:focus {
    border-color: var(--color-accent);
  }
  .newsletter__btn {
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
}
</style>
