---
/**
 * Newsletter signup component — direct POST to Brevo.
 * No hidden forms, no relay, no main.js, no reCAPTCHA.
 * Props:
 *   variant: 'section' (full-width homepage block) | 'inline' (compact footer block)
 *   id:       unique form id to avoid clashes when used multiple times on a page
 */
interface Props {
  variant?: 'section' | 'inline';
  id?: string;
}
const { variant = 'section', id = 'newsletter' } = Astro.props;

const BREVO_ACTION = "https://15cb987e.sibforms.com/serve/MUIFAOZOhVEOxVZXjAAbooSnqx_Shx1D0TJ7VqThHXBGpaAJiibkpWkVTFONEaQfYJjo7vpjpjisYLFNm0LfqQU4xLxGOUcm-7S-XiAlMFE1RtOQrNGO8SEX4bU-juKJitGkzafoMRfhcRLfUCpPV46BLpnfCk3TtCKRa_8JkE7bSr5hIvj02jmuWXjPWpC-TEMEv3pWpZemi9WfyQ==";
---

{variant === 'section' ? (
  <!-- Full homepage newsletter block -->
  <section class="newsletter" aria-labelledby={`${id}-heading`}>
    <div class="container newsletter__inner">
      <div class="newsletter__content">
        <span class="section-label" style="color:var(--color-accent)">Stay Connected</span>
        <h2 id={`${id}-heading`} class="newsletter__title">Get Europe Travel Tips, Visa Updates &amp; Exclusive Deals</h2>
        <p class="newsletter__desc">Join 2,000+ travellers who get our weekly insider tips — destination guides, visa checklists, seasonal deals and more. Unsubscribe anytime.</p>
      </div>

      <div class="newsletter__form-container">
        <!-- Result UI (Initially Hidden) -->
        <div class="newsletter__success-ui" id={`${id}-success-ui`} style="display:none;">
          <div class="newsletter__feedback newsletter__feedback--success" style="display:block;">
            ✅ <strong>Confirm your subscription!</strong> We've sent an email to your inbox. Please check it to join.
          </div>
          <button type="button" class="btn btn--ghost" style="margin-top:var(--space-4); color:white; border-color:hsla(0,0%,100%,0.2)" onclick={`document.getElementById('${id}-form').style.display='flex'; document.getElementById('${id}-success-ui').style.display='none';`}>
            ← Join with another email
          </button>
        </div>

        <!-- Silent Form Submission -->
        <form 
          class="newsletter__form" 
          id={`${id}-form`}
          method="POST"
          action={BREVO_ACTION}
          target="newsletter_silent_frame"
          onsubmit={`document.getElementById('${id}-form').style.display='none'; document.getElementById('${id}-success-ui').style.display='block';`}
        >
          <div class="newsletter__field-row">
            <div class="newsletter__input-wrap">
              <input
                type="email"
                name="EMAIL"
                required
                placeholder="Your email address"
                class="newsletter__input"
                aria-label="Email address"
              />
            </div>
            <input type="text" name="email_address_check" value="" style="display:none;" />
            <input type="hidden" name="locale" value="en" />
            
            <button type="submit" class="newsletter__btn">
              <span class="newsletter__btn-text">Subscribe</span>
            </button>
          </div>
          <label class="newsletter__consent">
            <input type="checkbox" name="OPT_IN" value="1" required />
            <span>I agree to receive emails from DURIAN Travel. <a href="/privacy-policy/">Privacy Policy</a></span>
          </label>
        </form>
      </div>
    </div>
  </section>
) : (
  <!-- Inline footer/compact version -->
  <div class="newsletter-inline" id={id}>
    <!-- Result UI -->
    <div id={`${id}-success-ui`} style="display:none;">
       <p class="footer__newsletter-label" style="color: #6ee7a0;">✅ Almost there! Check your inbox to confirm.</p>
    </div>

    <form 
      class="newsletter-inline__form" 
      id={`${id}-form`}
      method="POST"
      action={BREVO_ACTION}
      target="newsletter_silent_frame"
      onsubmit={`document.getElementById('${id}-form').style.display='none'; document.getElementById('${id}-success-ui').style.display='block';`}
    >
      <p class="footer__newsletter-label" id={`${id}-label`}>Subscribe for expert Europe travel strategies &amp; visa news.</p>
      <div class="footer__newsletter-form">
        <input
          type="email"
          name="EMAIL"
          required
          placeholder="Email address"
          class="footer__newsletter-input"
          aria-labelledby={`${id}-label`}
        />
        <input type="text" name="email_address_check" value="" style="display:none;" />
        <input type="hidden" name="locale" value="en" />
        
        <button type="submit" class="footer__newsletter-btn">
          <span class="newsletter__btn-text">Go</span>
        </button>
      </div>
      <label class="newsletter__consent" style="margin-top: var(--space-3); color: hsla(0,0%,100%,0.35);">
        <input type="checkbox" name="OPT_IN" value="1" required />
        <span>I agree to receive emails. <a href="/privacy-policy/">Privacy</a></span>
      </label>
    </form>
  </div>
)}

<!-- Hidden Iframe to capture the POST redirect and keep user on page -->
<iframe name="newsletter_silent_frame" id="newsletter_silent_frame" style="display:none;"></iframe>

<style>
/* ══════════════════════════════════════════
   NEWSLETTER SECTION (homepage full-width)
   ══════════════════════════════════════════ */
.newsletter {
  background: var(--color-navy);
  padding-block: var(--space-16);
  border-top: 3px solid var(--color-accent);
  position: relative;
  overflow: hidden;
}
.newsletter::before {
  content: '';
  position: absolute;
  top: -60%;
  right: -10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(196, 75, 54, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.newsletter::after {
  content: '';
  position: absolute;
  bottom: -40%;
  left: -5%;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(27, 58, 92, 0.25) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.newsletter__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: center;
  position: relative;
  z-index: 1;
}
@media (max-width: 800px) {
  .newsletter__inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
    text-align: center;
  }
}

.newsletter__title {
  font-family: var(--font-serif);
  font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
  font-weight: 400;
  color: white;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-4);
}
.newsletter__desc {
  color: hsla(0, 0%, 100%, 0.6);
  font-size: var(--text-base);
  line-height: var(--leading-relaxed);
  max-width: 480px;
}
@media (max-width: 800px) {
  .newsletter__desc { margin-inline: auto; }
}

/* Form */
.newsletter__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}
.newsletter__field-row {
  display: flex;
  gap: 0;
}
.newsletter__input-wrap {
  flex: 1;
}
.newsletter__input {
  width: 100%;
  padding: var(--space-4) var(--space-5);
  font-size: var(--text-base);
  background: hsla(0, 0%, 100%, 0.08);
  border: 1px solid hsla(0, 0%, 100%, 0.2);
  border-right: none;
  border-radius: var(--radius-md) 0 0 var(--radius-md);
  color: white;
  outline: none;
  transition: border-color var(--transition-fast);
}
.newsletter__input::placeholder {
  color: hsla(0, 0%, 100%, 0.4);
}
.newsletter__input:focus {
  border-color: var(--color-accent);
}
.newsletter__btn {
  padding: var(--space-4) var(--space-8);
  font-size: var(--text-sm);
  font-weight: var(--font-bold);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  background: var(--color-accent);
  color: white;
  border: 1px solid var(--color-accent);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  cursor: pointer;
  transition: background var(--transition-fast);
  white-space: nowrap;
  position: relative;
}
.newsletter__btn:hover {
  background: var(--color-accent-dark);
}

/* Consent checkbox */
.newsletter__consent {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  font-size: var(--text-xs);
  color: hsla(0, 0%, 100%, 0.5);
  cursor: pointer;
  line-height: var(--leading-relaxed);
}
.newsletter__consent input[type="checkbox"] {
  margin-top: 3px;
  accent-color: var(--color-accent);
  flex-shrink: 0;
}
.newsletter__consent a {
  color: hsla(0, 0%, 100%, 0.7);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.newsletter__consent a:hover {
  color: white;
}

/* Success UI Styling */
.newsletter__success-ui {
  animation: feedbackSlide 0.4s ease;
}

/* Feedback messages from previous iteration used in success UI */
.newsletter__feedback {
  font-size: var(--text-base);
  padding: var(--space-5);
  border-radius: var(--radius-md);
}
.newsletter__feedback--success {
  background: hsla(150, 60%, 40%, 0.15);
  color: #6ee7a0;
  border: 1px solid hsla(150, 60%, 40%, 0.3);
}

@keyframes feedbackSlide {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════════════════
   NEWSLETTER INLINE (footer version)
   ══════════════════════════════════════════ */
.footer__newsletter-label {
  font-size: var(--text-sm);
  margin-bottom: var(--space-4);
  color: hsla(0, 0%, 100%, 0.75);
}
.footer__newsletter-form {
  display: flex;
  gap: 0;
}
.footer__newsletter-input {
  flex: 1;
  background: hsla(0, 0%, 100%, 0.05);
  border: 1px solid hsla(0, 0%, 100%, 0.1);
  border-right: none;
  border-radius: var(--radius-sm) 0 0 var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  color: white;
  font-size: var(--text-sm);
  outline: none;
}
.footer__newsletter-input:focus {
  border-color: hsla(0, 0%, 100%, 0.3);
}
.footer__newsletter-btn {
  background: var(--color-accent);
  color: white;
  border: none;
  padding-inline: var(--space-5);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-weight: var(--font-bold);
  font-size: var(--text-xs);
  text-transform: uppercase;
  cursor: pointer;
}
.footer__newsletter-btn:hover {
  background: var(--color-accent-dark);
}

@media (max-width: 600px) {
  .newsletter__field-row {
    flex-direction: column;
    gap: var(--space-3);
  }
  .newsletter__input {
    border-radius: var(--radius-md);
    border-right: 1px solid hsla(0, 0%, 100%, 0.2);
  }
  .newsletter__btn {
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
}
</style>
