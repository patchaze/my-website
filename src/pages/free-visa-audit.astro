---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free Travel Readiness Audit | 15 Min Strategy Review | DURIAN Travel"
  description="Book a free 20-minute travel and visa readiness audit with a European travel consultant. We'll identify gaps in your documents and recommend next steps."
  breadcrumb={[{ name: 'Free Audit', url: 'https://www.duriantravel.com/free-visa-audit/' }]}
  keywords="free visa audit, Schengen visa consult, free travel consultation, check visa documents for free"
>

  <section class="hero-sm hero-gradient">
    <div class="container text-center">
      <span class="section-label" style="color:var(--color-accent-light)">Free — No Commitment</span>
      <h1 class="hero-sm__title" style="color:white;max-width:44ch;margin-inline:auto">
        Get a Free 15-Minute Visa Readiness Audit
      </h1>
      <p class="hero-sm__subtitle" style="margin-inline:auto;text-align:center">
        Tell us about your upcoming application. We'll identify the biggest risks
        and tell you exactly what to prioritise — in 15 minutes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="audit-layout">
        <!-- Form -->
        <div class="audit-form-wrap">
          <h2 style="margin-bottom:var(--space-6)">Book Your Free Audit</h2>

          <!-- Calendly inline widget begin -->
          <div class="calendly-inline-widget" data-url="https://calendly.com/contact-duriantravel/durian-travel-15-minute-audit?hide_event_type_details=1&hide_gdpr_banner=1" style="min-width:320px;height:700px;"></div>
          <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
          <!-- Calendly inline widget end -->
        </div>

        <!-- What's included sidebar -->
        <div class="audit-sidebar">
          <div class="audit-card">
            <h3 style="margin-bottom:var(--space-4)">What's Included</h3>
            <ul class="check-list">
              <li>Quick review of your travel plan</li>
              <li>Document gap identification</li>
              <li>Risk assessment for your profile</li>
              <li>Honest assessment — we'll tell you if you don't need our services</li>
              <li>Recommendation for next steps</li>
            </ul>
          </div>

          <div class="audit-card">
            <h3 style="margin-bottom:var(--space-4)">What This Is Not</h3>
            <ul class="x-list">
              <li>A sales call</li>
              <li>A guarantee of visa approval</li>
              <li>Legal advice or representation</li>
              <li>Application submission</li>
            </ul>
          </div>

          <div class="notice notice--info">
            <span>💡</span>
            <p>
              <strong>Why free?</strong> Because most visa mistakes are preventable.
              A 15-minute review can save you weeks of delay and hundreds in reapplication fees.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.hero-sm { padding-block: var(--space-16); }
.hero-sm__title { font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl)); margin-bottom: var(--space-4); }
.hero-sm__subtitle { font-size: var(--text-lg); color: hsl(150 30% 75%); max-width: 52ch; line-height: var(--leading-relaxed); }

.audit-layout {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: var(--space-12);
  align-items: start;
}
@media (max-width: 860px) { .audit-layout { grid-template-columns: 1fr; } }

.audit-form-wrap {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
}
.audit-form { display: flex; flex-direction: column; gap: var(--space-5); }

.audit-sidebar { display: flex; flex-direction: column; gap: var(--space-6); }
.audit-card {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
}
</style>
