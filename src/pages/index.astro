---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';

import { Picture, getImage } from 'astro:assets';
import heroImg from '../assets/images/dolomites-sunset.jpg';
import amalfiImg from '../assets/images/amalfi-coast-italy.png';
import alpsImg from '../assets/images/zermatt-matterhorn.png';

const testimonials = [
  {
    quote: "DURIAN planned our honeymoon in France from start to finish. Every detail — the château stay, the private wine tasting, the restaurant bookings — was flawless. We didn't have to think once.",
    author: "Emily & James — London-based expats traveling on non-EU passports"
  },
  {
    quote: "The document review saved my visa application. They caught a critical error in my financial proof that would have led to a refusal. Approved first try.",
    author: "Sarah M. — New York, USA"
  },
  {
    quote: "Fast responses and genuinely deep local knowledge. They didn't just book hotels — they built a story for our family trip to Portugal. Worth every peso.",
    author: "Mark T. — Sydney, Australia"
  }
];

const trustStats = [
  { value: '98%', label: 'Schengen Approval Rate' },
  { value: 'Human', label: 'Reviewed Strategy' },
  { value: 'Custom', label: 'Itineraries, Not Templates' },
  { value: 'Real', label: 'Support When Plans Change' }
];

const serviceCards = [
  {
    title: 'Schengen Visa Strategy',
    body: 'We review your documents, identify refusal risks, and prepare your application so it meets strict embassy requirements. 98% of our clients are approved on first try.',
    href: '/services/#schengen-blueprint',
    linkText: 'Find out how →'
  },
  {
    title: 'Custom Europe Itineraries',
    body: 'Each itinerary is built around your passport, pace, and interests — not a template. We design optimized daily routes with logical sequencing across multiple countries.',
    href: '/services/#first-journey',
    linkText: 'Learn more →'
  },
  {
    title: 'Handpicked European Stays',
    body: 'Boutique hotels, private villas, and character-rich properties selected by hand. No generic chain recommendations.',
    href: '/services/#grand-circuit',
    linkText: 'Discover stays →'
  },
  {
    title: 'On-Trip Support',
    body: 'Real English-speaking agents available when plans change mid-trip. Not a chatbot. Not an FAQ page.',
    href: '/services/#grand-circuit',
    linkText: 'See experiences →'
  }
];

const processSteps = [
  {
    number: '01',
    title: 'Tell Us About Your Trip',
    body: 'Share your travel window, origin country, passport, and rough interests. No lengthy forms — just a conversation.'
  },
  {
    number: '02',
    title: 'We Build Your Plan',
    body: 'We design your itinerary, flag your Schengen requirements, and prepare your documentation strategy — reviewed by a human, not generated by a template.'
  },
  {
    number: '03',
    title: 'Travel With Confidence',
    body: 'Go to Europe with a clean itinerary, approved visa documents, and a support line if anything changes on the ground.'
  }
];

import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map(post => ({
    title: post.data.title,
    description: post.data.description,
    slug: post.slug,
    pubDate: post.data.pubDate.toISOString(),
    tags: post.data.tags,
    readTime: post.data.readTime
  }));

const strategySpotlight = [
  {
    label: 'Checklist',
    title: 'Schengen Document Checklist',
    desc: 'The cleanest universal starting point for passports, insurance, bookings, and financial proof.',
    href: '/blog/schengen-document-checklist/'
  },
  {
    label: 'Itinerary',
    title: '10-Day Europe Itinerary for First-Time Travelers',
    desc: 'A cleaner first-Europe route built around two strong bases instead of exhausting one-night stops.',
    href: '/blog/10-day-europe-itinerary/'
  },
  {
    label: 'Route Logic',
    title: 'Multi-Country Europe Itinerary',
    desc: 'How to sequence cities, borders, and transfer days without turning the trip into luggage churn.',
    href: '/blog/multi-country-europe-itinerary/'
  },
  {
    label: 'Budget',
    title: 'Europe Trip Budget Guide',
    desc: 'A realistic breakdown of flights, hotels, rail, food, and buffer money before you book.',
    href: '/blog/europe-trip-budget/'
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the financial bank balance requirements for a Schengen visa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To meet the financial proof requirements for a Schengen visa, applicants must demonstrate a stable and consistent bank balance covering at least €50 to €150 per day of their planned Europe trip. European embassies require 3 to 6 months of official bank statements showing regular income rather than sudden large deposits. A clear financial cover letter explaining any account discrepancies can help officers understand unusual account activity."
      }
    },
    {
      "@type": "Question",
      "name": "How do I plan a multi-country Europe trip itinerary?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Planning a multi-country Europe trip itinerary requires balancing travel pace, efficient transport routes like the Eurail network, and strategic accommodation choices. A well-optimized European travel itinerary avoids one-night stays and groups neighboring destinations to minimize transit time. Working with a specialist who knows European rail networks and pacing logic will save you significant time and reduce costly mistakes."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need fully paid flight tickets before applying for a Schengen visa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, European embassies do not require fully paid non-refundable flight tickets before a Schengen visa is approved. Instead, applicants should provide a verifiable flight reservation or flight itinerary for visa purposes. Submitting fully paid tickets poses a significant financial risk if the visa is denied. Expert Schengen visa document review services highly recommend using placeholder reservations until the visa is officially granted."
      }
    },
    {
      "@type": "Question",
      "name": "What are the most common reasons for a Schengen visa refusal?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common reasons for a Schengen visa refusal include insufficient proof of financial means, vague or illogical travel itineraries, lack of strong socio-economic ties to the home country, and inconsistent documentation. A minor error in the Schengen visa application form or cover letter can easily lead to rejection. A comprehensive visa refusal analysis and document strategy review can identify and resolve these red flags before submission."
      }
    },
    {
      "@type": "Question",
      "name": "Can a travel agency or immigration lawyer guarantee a Schengen visa approval?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No agency, consultant, or immigration lawyer can legally guarantee a Schengen visa approval, as the final decision rests solely with the consular officers of the European embassy. Working with an experienced consultant for document review significantly reduces refusal risk by ensuring your application is logically consistent and complete before submission."
      }
    }
  ]
};

// Pre-generate hero image for LCP preload hint
const heroAvif480 = await getImage({ src: heroImg, width: 480, format: 'avif' });
const heroAvif800 = await getImage({ src: heroImg, width: 800, format: 'avif' });
const heroAvif1200 = await getImage({ src: heroImg, width: 1200, format: 'avif' });
const heroAvif1920 = await getImage({ src: heroImg, width: 1920, format: 'avif' });
const lcpAvifSrcset = `${heroAvif480.src} 480w, ${heroAvif800.src} 800w, ${heroAvif1200.src} 1200w, ${heroAvif1920.src} 1920w`;
---

<BaseLayout
  title="Europe Trip Planning & Visa Support | DURIAN Travel"
  description="Custom Europe itineraries and Schengen visa strategy for non-European travelers - wherever in the world you're planning from."
  ogImage="https://www.duriantravel.com/dolomites-sunset.webp"
  schema={faqSchema}
  lcpImageSrcset={lcpAvifSrcset}
  lcpImageSizes="100vw"
  keywords="Europe trip planning for non-Europeans, custom Europe itineraries, Schengen visa strategy, first Europe trip planning, Europe travel consultancy"
>

  <!-- HERO — Full-bleed with floating glass cards -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__bg-full">
      <Picture src={heroImg} alt="Italy Dolomites at sunset – European Alps." widths={[480, 800, 1200, 1920]} sizes="(max-width: 480px) 480px, (max-width: 800px) 800px, 100vw" formats={['avif', 'webp']} fallbackFormat="jpg" loading="eager" fetchpriority="high" />
      <div class="hero__overlay-dark"></div>
    </div>
    
    <div class="container hero__grid">
      <!-- Left: Content Overlay -->
      <div class="hero__info">
        <div class="hero__badge">
          <span class="hero__badge-icon">📍</span>
          EUROPE TRIP PLANNING
        </div>
        <h1 id="hero-heading" class="hero__title">
          Europe Trip Planning
          <span class="hero__title-glow">&amp; Visa Support</span>
        </h1>
        <p class="hero__description">
          Custom Europe itineraries and Schengen visa strategy for non-European travelers - wherever in the world you're planning from.
        </p>
        <div class="hero__buttons">
          <a href="/contact/" class="btn-primary">Get a Custom Itinerary</a>
          <a href="#how-it-works" class="hero__secondary-link">See How It Works →</a>
        </div>
      </div>

      <!-- Right: Floating destination cards -->
      <div class="hero__visuals">
        <a href="/destinations/italy/" class="glass-card glass-card--1 hero-link" aria-label="Explore Italy">
          <Picture src={amalfiImg} alt="Amalfi Coast cliffside over Mediterranean Sea." widths={[300, 600]} sizes="(max-width: 600px) 300px, 300px" formats={['avif', 'webp']} fallbackFormat="png" height={400} loading="lazy" decoding="async" />
          <div class="glass-card__info">
            <p class="glass-card__location">📍 Amalfi Coast, Italy</p>
          </div>
          <div class="hero-link-overlay"><span class="explore-btn">Explore Italy</span></div>
        </a>
        <a href="/destinations/switzerland/" class="glass-card glass-card--2 hero-link" aria-label="Explore Switzerland">
          <Picture src={alpsImg} alt="Zermatt and Matterhorn in Swiss Alps, Switzerland." widths={[300, 600]} sizes="(max-width: 600px) 300px, 300px" formats={['avif', 'webp']} fallbackFormat="png" height={400} loading="lazy" decoding="async" />
          <div class="glass-card__info">
            <p class="glass-card__location">📍 Swiss Alps, Switzerland</p>
          </div>
          <div class="hero-link-overlay"><span class="explore-btn">Explore Switzerland</span></div>
        </a>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="Durian Travel proof points">
    <div class="container">
      <div class="trust-strip__grid">
        {trustStats.map((item) => (
          <div class="trust-strip__item">
            <strong class="trust-strip__value">{item.value}</strong>
            <span class="trust-strip__label">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="problem-heading">
    <div class="container container--narrow">
      <header class="section-header text-center">
        <span class="section-label">The Problem We Solve</span>
        <h2 id="problem-heading" class="section-title">Planning Europe from Outside Europe Is a Different Challenge</h2>
      </header>
      <div class="problem-copy">
        <p>European travel guides assume you already understand Schengen zones, don't need a visa, and can easily hop between countries. For travelers planning from outside Europe, that's rarely the reality.</p>
        <p>You're navigating visa applications that can be refused for reasons nobody warned you about. You're building itineraries across three or four countries with no clear logic for how to sequence them. You're spending hours in Reddit threads getting contradictory advice from people who have never held your passport.</p>
        <p>Durian Travel exists for exactly this situation. We build your Europe trip from the outside in — starting with your passport, your visa requirements, and your travel window — then designing an itinerary that actually works.</p>
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="services-help-heading">
    <div class="container">
      <header class="section-header">
        <span class="section-label">How We Help</span>
        <h2 id="services-help-heading" class="section-title">What We Do For You</h2>
      </header>
      <div class="services-grid-home">
        {serviceCards.map((card) => (
          <article class="service-card-home">
            <h3 class="service-card-home__title">{card.title}</h3>
            <p class="service-card-home__body">{card.body}</p>
            <a href={card.href} class="service-card-home__link">{card.linkText}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="how-it-works" class="section" aria-labelledby="process-heading">
    <div class="container">
      <header class="section-header text-center">
        <span class="section-label">Our Process</span>
        <h2 id="process-heading" class="section-title">What Working With Durian Travel Looks Like</h2>
      </header>
      <div class="process-grid">
        {processSteps.map((step) => (
          <article class="process-step">
            <div class="process-step__num">{step.number}</div>
            <div class="process-step__content">
              <h3 class="process-step__title">{step.title}</h3>
              <p class="process-step__desc">{step.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="audience-heading">
    <div class="container container--narrow">
      <header class="section-header text-center">
        <span class="section-label">Who We Help</span>
        <h2 id="audience-heading" class="section-title">We Specialize in One Kind of Traveler</h2>
      </header>
      <div class="problem-copy text-center">
        <p>You're planning your first or second trip to Europe from outside the continent. You're excited — but you're also aware there are things you don't know. Visa rules that differ by embassy. Multi-country routes that can get complicated fast. Accommodation that ranges from excellent to deeply regrettable.</p>
        <p>You want someone who has done this before, for people exactly like you, and can hand you a plan you can actually trust. We've built Europe trips for travelers planning from outside Europe across very different passports, budgets, and travel styles. The starting point changes. The challenge is almost always the same.</p>
        <div class="who-we-help__cta">
          <a href="/about-us/" class="btn btn--secondary">See If We're Right For You →</a>
        </div>
      </div>
    </div>
  </section>


  <!-- TESTIMONIALS — Dark background, centered serif -->
  <section class="testimonials-dark" aria-labelledby="testimonials-heading">
    <div class="container">
      <header class="text-center" style="margin-bottom:var(--space-8)">
        <span class="section-label" style="color:var(--color-accent)">What Our Clients Say</span>
      </header>
      <div class="testimonial-slider">
        <div class="testimonial-track" id="testimonial-track">
          {testimonials.map((t, i) => (
            <div class="testimonial-slide" id={`testimonial-${i}`}>
              <blockquote class="testimonial-hero">
                <p class="testimonial-hero__quote">"{t.quote}"</p>
                <footer class="testimonial-hero__footer">
                  <strong>{t.author}</strong>
                </footer>
              </blockquote>
            </div>
          ))}
        </div>
        <div class="testimonial-hero__dots">
          {testimonials.map((_, i) => (
             <button 
               class="testimonial-dot" 
               aria-label={`Go to slide ${i + 1}`}
               data-slide={i}
             ></button>
          ))}
        </div>
      </div>

      <script is:inline>
        document.querySelectorAll('.testimonial-dot').forEach(dot => {
          dot.addEventListener('click', () => {
            const slideId = `testimonial-${dot.dataset.slide}`;
            const track = document.getElementById('testimonial-track');
            const slide = document.getElementById(slideId);
            if (track && slide) {
              track.scrollTo({
                left: slide.offsetLeft,
                behavior: 'smooth'
              });
            }
            
            // Update active state
            document.querySelectorAll('.testimonial-dot').forEach(d => d.classList.remove('active'));
            dot.classList.add('active');
          });
        });
        
        // Initial active state
        document.querySelector('.testimonial-dot')?.classList.add('active');

        // Update active dot on scroll
        const track = document.getElementById('testimonial-track');
        if (track) {
          track.addEventListener('scroll', () => {
            const index = Math.round(track.scrollLeft / track.offsetWidth);
            document.querySelectorAll('.testimonial-dot').forEach((d, i) => {
              d.classList.toggle('active', i === index);
            });
          });
        }
      </script>
    </div>
  </section>

  <section class="section section--alt" aria-labelledby="spotlight-heading">
    <div class="container">
      <header class="section-header">
        <div class="flex-between" style="flex-wrap:wrap;gap:var(--space-4)">
          <div>
            <span class="section-label">Planning Spotlight</span>
            <h2 id="spotlight-heading" class="section-title">Best Starting Points Right Now</h2>
          </div>
        </div>
      </header>
      <div class="spotlight-grid">
        {strategySpotlight.map(item => (
          <a href={item.href} class="spotlight-card">
            <span class="spotlight-card__label">{item.label}</span>
            <strong class="spotlight-card__title">{item.title}</strong>
            <span class="spotlight-card__desc">{item.desc}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG PREVIEW -->
  <section class="section" aria-labelledby="blog-heading">
    <div class="container">
      <header class="section-header">
        <div class="flex-between" style="flex-wrap:wrap;gap:var(--space-4)">
          <div>
            <span class="section-label">Latest Insights</span>
            <h2 id="blog-heading" class="section-title">From the Journal</h2>
          </div>
          <a href="/blog/" class="btn btn--secondary">View All Posts →</a>
        </div>
      </header>
      <div class="grid-3">
        {recentPosts.map(p => <BlogCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" aria-labelledby="faq-heading">
    <div class="container">
      <header class="section-header text-center">
        <span class="section-label">FAQ</span>
        <h2 id="faq-heading" class="section-title">Common Questions</h2>
      </header>
      
      <div class="faq-grid-custom">
        <div class="faq-item-custom">
          <h3>What are the financial bank balance requirements for a Schengen visa?</h3>
          <p>To meet the financial proof requirements for a Schengen visa, applicants must demonstrate a stable and consistent bank balance covering at least <strong>€50 to €150 per day</strong> of their planned Europe trip. European embassies require 3 to 6 months of official bank statements showing regular income rather than sudden large deposits. <strong>A clear financial cover letter explaining any account discrepancies</strong> can help officers understand unusual account activity.</p>
        </div>
        <div class="faq-item-custom">
          <h3>How do I plan a multi-country Europe trip itinerary?</h3>
          <p>Planning a multi-country Europe trip itinerary requires balancing travel pace, efficient transport routes like the Eurail network, and strategic accommodation choices. A well-optimized European travel itinerary avoids one-night stays and groups neighboring destinations to minimize transit time. <strong>Working with a specialist who knows European rail networks and pacing logic will save you significant time and reduce costly mistakes.</strong></p>
        </div>
        <div class="faq-item-custom">
          <h3>Do I need fully paid flight tickets before applying for a Schengen visa?</h3>
          <p>No, European embassies do not require fully paid non-refundable flight tickets before a Schengen visa is approved. Instead, applicants should provide a verifiable <strong>flight reservation or flight itinerary</strong> for visa purposes. Submitting fully paid tickets poses a significant financial risk if the visa is denied. Expert Schengen visa document review services highly recommend using placeholder reservations until the visa is officially granted.</p>
        </div>
        <div class="faq-item-custom">
          <h3>What are the most common reasons for a Schengen visa refusal?</h3>
          <p>The most common reasons for a Schengen visa refusal include <strong>insufficient proof of financial means</strong>, vague or illogical travel itineraries, lack of strong socio-economic ties to the home country, and inconsistent documentation. A minor error in the Schengen visa application form or cover letter can easily lead to rejection. A comprehensive <strong>visa refusal analysis</strong> and document strategy review can identify and resolve these red flags before submission.</p>
        </div>
        <div class="faq-item-custom" style="grid-column: 1 / -1;">
          <h3>Can a travel agency or immigration lawyer guarantee a Schengen visa approval?</h3>
          <p>No agency, consultant, or immigration lawyer can legally guarantee a Schengen visa approval, as the final decision rests solely with the consular officers of the European embassy. <strong>Working with an experienced consultant for document review significantly reduces refusal risk by ensuring your application is logically consistent and complete before submission.</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST / E-E-A-T -->
  <section class="section" aria-labelledby="trust-heading">
    <div class="container container--narrow">
      <header class="section-header text-center">
        <span class="section-label">Why Clients Trust Us</span>
        <h2 id="trust-heading" class="section-title">Built on Expertise</h2>
      </header>
      <ul class="trust-list">
        <li class="trust-item"><strong>Founded by specialists:</strong> European travel experts focused on non-European travelers and real-world route logic.</li>
        <li class="trust-item"><strong>Visa success:</strong> 98% of clients receive Schengen approval on first application.</li>
        <li class="trust-item"><strong>Human-reviewed plans:</strong> Every itinerary and document package is reviewed by a real consultant — not auto-generated.</li>
        <li class="trust-item"><strong>Vetted partner network:</strong> Hotels, guides, and operators across Europe selected for fit, not generic inventory.</li>
        <li class="trust-item"><strong>24/7 on-trip support:</strong> Real English-speaking agents when plans change mid-journey.</li>
      </ul>
    </div>
  </section>

  <div class="container">
    <p class="entity-paragraph">
      Durian Travel is a Europe trip planning consultancy specializing in custom itineraries and Schengen visa strategy for non-European travelers. Founded by European travel specialists, Durian Travel helps travelers planning from outside Europe navigate multi-country itineraries and Schengen visa documentation from application to approval.
    </p>
  </div>

</BaseLayout>

<style>
/* ══════════════════════════════════════════
   HERO — Full-bleed with floating glass cards
   ══════════════════════════════════════════ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  color: white;
  overflow: hidden;
  padding-top: 80px; /* Account for fixed header if any */
}

@media (max-width: 900px) {
  .hero {
    min-height: auto;
    padding-top: 80px;
    padding-bottom: var(--space-8);
  }
}

.audience-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  justify-content: center;
}

.audience-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.7rem 1rem;
  border-radius: 999px;
  background: white;
  border: 1px solid var(--color-border);
  color: var(--color-heading);
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  box-shadow: 0 8px 24px hsl(0 0% 0% / 0.05);
}

@media (max-width: 768px) {
  .hero {
    min-height: auto;
    height: auto;
    padding-top: 60px;
    padding-bottom: var(--space-8);
  }
}

.hero__bg-full {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__bg-full img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.hero__overlay-dark {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(15, 33, 56, 0.85) 0%,
    rgba(15, 33, 56, 0.4) 50%,
    rgba(15, 33, 56, 0.2) 100%
  );
}

.hero__grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  align-items: center;
  gap: var(--space-8);
  width: 100%;
}
@media (max-width: 992px) {
  .hero__grid {
    grid-template-columns: 1fr;
    text-align: center;
    padding-bottom: var(--space-12);
  }
}

@media (max-width: 768px) {
  .hero__grid {
    padding-bottom: 0;
    gap: var(--space-8);
  }
}

/* Left: Info */
.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: var(--color-accent);
  color: white;
  padding: 6px 16px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  letter-spacing: 0.1em;
  margin-bottom: var(--space-6);
  box-shadow: 0 4px 12px rgba(196, 75, 54, 0.3);
}
@media (max-width: 992px) { .hero__badge { margin-inline: auto; } }

.hero__title {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 400;
  line-height: 1.1;
  margin-bottom: var(--space-6);
  color: white;
}
@media (max-width: 768px) {
  .hero__title {
