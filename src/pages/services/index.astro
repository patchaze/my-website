---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';

const packages = [
  {
    slug: 'schengen-blueprint',
    name: 'The Schengen Blueprint',
    sub: 'Europe visa + itinerary',
    icon: '✦',
    tone: 'blueprint',
    target:
      'First-time Schengen applicants from outside Europe - North Americans, South Americans, Africans, Asians, and Australians facing complex embassy requirements, financial proof scrutiny, and unfamiliar European itinerary logic.',
    tagline:
      'Europe, planned to the document. Your visa application, itinerary, and trip architecture handled by people who understand both the embassy and the destination.',
    included: [
      'Full Schengen visa strategy session (60 min)',
      'Document stack review + written gap report',
      'Cover letter written and reviewed',
      'Itinerary built for visa + actual travel (not just embassy compliance)',
      'Financial proof coaching (bank statement structure, adequate balance guidance)',
      'Multi-country routing logic (entry point selection, 90/180-day planning)',
      'Unlimited email Q&A through submission date',
    ],
    differentiators: [
      'Embassy-specific coaching (France vs Germany vs Italy differ significantly)',
      'Cover letter that reads like a human wrote it',
      'Real refusal-prevention review, not just a checklist',
    ],
    healthLabel: 'Travel health layer included',
    healthItems:
      'Pre-departure pharmacist briefing on Schengen health insurance requirements, OTC medication allowances by country (France, Germany, and Italy have different rules), and EU medication import checklist for prescription travelers.',
    addons: [
      'Refusal analysis + reapplication strategy',
      'Additional destination added to itinerary',
      'Express turnaround (48-hour document review)',
      'Airport transit coaching (Schengen entry ports)',
      'Family application bundle (2+ travelers)',
    ],
    geo: [
      {
        region: 'Southeast Asian & African applicants',
        items: [
          'VFS Global appointment prep',
          'Employment and income document structuring by country',
          'Financial proof for non-standard income (remittance, freelance, business)',
          'Civil registry document checklist by nationality',
        ],
      },
      {
        region: 'North American applicants',
        items: [
          'Embassy in-home-country vs abroad options',
          'US/Canadian financial equivalence docs',
          'ESTA vs Schengen overlap planning',
        ],
      },
    ],
  },
  {
    slug: 'first-journey',
    name: 'The First Journey Package',
    sub: 'First-time international traveler',
    icon: '◈',
    tone: 'journey',
    target:
      "Someone planning their first international trip - anxious, overwhelmed by visa logistics, unsure what 'enough money in the bank' actually means, and likely to abandon the process without guidance.",
    tagline:
      "For the traveler who's never done this before. We take you from passport in hand to boarding gate - step by step, no jargon, no guessing.",
    included: [
      'Trip readiness assessment (what you have, what you\'re missing)',
      'Destination selection consultation based on your passport, budget, and timeline',
      'Full visa application strategy for chosen destination',
      'First-timer itinerary: pacing, realistic costs, what to book vs what to leave flexible',
      'Pre-departure checklist (documents, currency, insurance, health prep)',
      'WhatsApp/email support window: 2 weeks before and 1 week after departure',
      'Emergency contact list + what-to-do-if guide',
    ],
    differentiators: [
      'The only package that starts from zero - no assumed knowledge',
      'Travel anxiety addressed directly, not glossed over',
      'Human, jargon-free communication style throughout',
    ],
    healthLabel: 'First-timer health briefing included',
    healthItems:
      'Destination-specific vaccine status check (what\'s recommended vs required), travel pharmacy starter kit guidance (what to pack, what you can buy there), jet lag management protocol for long-haul first-timers, and motion sickness, altitude, and food safety briefing by a licensed pharmacist.',
    addons: [
      'Airport meet-and-greet coordination (third-party referral)',
      'Travel SIM card guidance + setup',
      'Luggage allowance + airline rule coaching',
      'Currency exchange strategy session',
      'Post-trip debrief (for next trip planning)',
    ],
    geo: [
      {
        region: 'Southeast Asian first-timers',
        items: [
          'Visa-required routes from Indonesia, Vietnam, Thailand, and neighbouring countries',
          'Budget airline vs full-service coaching',
          'Non-traditional income financial proof strategies',
        ],
      },
      {
        region: 'African first-timers',
        items: [
          'High-scrutiny embassy preparation',
          'Invitation letter and host documentation',
          'Strong ties-to-home documentation coaching',
        ],
      },
    ],
  },
  {
    slug: 'nomad-infrastructure',
    name: 'The Nomad Infrastructure Plan',
    sub: 'Long-stay + digital nomads',
    icon: '◎',
    tone: 'nomad',
    target:
      'Remote workers and digital nomads planning extended stays in Europe, Southeast Asia, or South America - needing multi-entry visa strategies, tax-aware planning, and health logistics that survive a 3+ month trip.',
    tagline:
      'Built for people who travel for months, not weeks. Visa architecture, health continuity, and itinerary logic designed for the long haul.',
    included: [
      'Multi-destination Schengen 90/180-day calculation and planning',
      'Non-Schengen buffer destination strategy (UK, Balkans, Georgia, Morocco, etc.)',
      'Multi-entry visa strategy per passport type',
      'Health coverage gap analysis for extended stays (insurance continuity)',
      'Prescription medication supply planning for 3+ month trips',
      'Remote work visa options assessment (Portugal D8, Spain Nomada, etc.)',
      'Accommodation-type strategy (short-term rental, co-living, hostel logic)',
    ],
    differentiators: [
      'The 90-day Schengen limit solved, not just acknowledged',
      'Medication supply continuity - something almost no travel service addresses',
      'Designed by someone who understands both the visa law and the pharmacy logistics',
    ],
    healthLabel: 'Extended-stay health protocol included',
    healthItems:
      '3-6 month medication supply strategy (prescription continuity across borders), European pharmacy equivalents for medications commonly used across Asia, Africa, and the Americas, long-stay travel insurance analysis (standard policies expire at 90 days), and mental wellness and burnout prevention brief for long-haul remote workers.',
    addons: [
      'Tax residency awareness brief (not legal advice)',
      'Crypto and international banking guide',
      'Co-working space and coliving research for target cities',
      'Emergency repatriation planning',
    ],
    geo: [
      {
        region: 'Asian & African nomads',
        items: [
          'Portugal D8, Spain Nomada, and other remote work visa eligibility by passport',
          'Schengen entry-point optimization',
          'Home-country tax compliance awareness (non-advisory)',
        ],
      },
      {
        region: 'North American nomads',
        items: [
          'US FBAR + reporting awareness brief',
          'Canadian health insurance gap analysis',
          'ESTA + Schengen sequencing strategy',
        ],
      },
    ],
  },
  {
    slug: 'family-expedition',
    name: 'The Family Expedition Bundle',
    sub: 'Multi-member + family groups',
    icon: '⬡',
    tone: 'family',
    target:
      'Families of 2-6 traveling together internationally, particularly those with children, elderly members, or health-specific needs - where a single missed document or medication gap affects the entire group.',
    tagline:
      "When one person's document or health issue grounds the whole family, you need a plan built for everyone - not just the primary applicant.",
    included: [
      'Group visa strategy for all applicants (coordinated timelines)',
      'Minor travel documentation guidance (parental consent, child travel authorization by country)',
      'Elderly traveler health and mobility planning',
      'Group itinerary with realistic pacing (not optimized for solo speed)',
      'Family-appropriate destination + accommodation research brief',
      'Insurance coordination for multi-member groups',
      'Emergency contact + split-group contingency planning',
    ],
    differentiators: [
      'The only package explicitly designed for the family unit as a system, not just the lead traveler',
      'Pediatric and elderly health considerations built in as standard',
      'Child travel authorization and parental consent process - rarely covered elsewhere',
    ],
    healthLabel: 'Family health layer included',
    healthItems:
      'Per-member medication review and travel pack guidance, pediatric travel health brief (vaccines, OTC dosing for children, food safety), elderly traveler assessment: mobility, chronic condition management, medical alert documentation, and a family-sized first aid kit list with pharmacist recommendations.',
    addons: [
      'School clearance letter template',
      'Family travel insurance comparison brief',
      'Accessible accommodation research (mobility needs)',
      'Child-friendly itinerary add-on for specific cities',
      'Multi-generational trip arbitration (when grandparents are joining)',
    ],
    geo: [
      {
        region: 'Southeast Asian families',
        items: [
          'Child travel authorization process by country of origin',
          'Multi-member VFS appointment coordination',
          'Split-household family application strategy (working parent abroad)',
        ],
      },
      {
        region: 'Diaspora families (abroad sponsor)',
        items: [
          'Invitation + sponsorship letter package',
          'Sponsor financial proof structure',
          'Family reunion visa documentation',
        ],
      },
    ],
  },
  {
    slug: 'recovery-route',
    name: 'The Recovery Route',
    sub: 'Post-refusal reapplication',
    icon: '◇',
    tone: 'recovery',
    target:
      'Travelers who received a Schengen or other visa refusal and need to understand exactly what went wrong, fix it, and reapply with a materially stronger application - without guessing.',
    tagline:
      "A refusal isn't the end. Most are fixable - if you understand the real reason and address it correctly. This package starts where your rejection letter stops.",
    included: [
      'Refusal letter interpretation (decoding embassy-speak)',
      'Root cause analysis of your specific refusal (financial, itinerary, ties, documentation)',
      'Reapplication strategy with a revised document plan',
      'New cover letter: specifically addresses the refusal reason',
      'Strengthened financial proof coaching',
      'Ties-to-home documentation upgrade plan',
      'Timing advice: when to reapply and to which embassy',
    ],
    differentiators: [
      'The only package that starts from a refusal and treats it as diagnostic data',
      "Embassy-code refusal reason interpretation - the letter rarely says what it means",
      'Reapplication timing strategy (applying too soon is a common second mistake)',
    ],
    healthLabel: 'Health documentation check included',
    healthItems:
      'Review of travel insurance for compliance with refusal grounds (if applicable), medical condition documentation coaching (if health was flagged), and reapplication travel health insurance sourcing guidance.',
    addons: [
      'Legal referral (if refusal grounds require professional legal advice)',
      'Alternative destination strategy (if the target country is temporarily inadvisable)',
      'Expedited 48-hour turnaround for urgent reapplication timelines',
      'Appeal letter drafting (where permitted)',
    ],
    geo: [
      {
        region: 'Southeast Asian applicants',
        items: [
          'Common refusal patterns for first-time applicants from the region (financial proof, travel history, ties to home)',
          'Embassy-switching strategy (Italian vs French vs German embassy)',
          'Employment and income document restructuring',
        ],
      },
      {
        region: 'African applicants',
        items: [
          'High-refusal-rate embassy specific strategies',
          'Invitation letter + sponsor documentation rebuild',
          'Travel history documentation for thin-passport applicants',
        ],
      },
    ],
  },
  {
    slug: 'wellness-journey',
    name: 'The Wellness Journey',
    sub: 'Health-led travel planning',
    icon: '✿',
    tone: 'wellness',
    target:
      "Travelers with chronic conditions, complex medication needs, post-surgery travel plans, elderly travelers, or anyone who has been told by a doctor 'you should be careful traveling' - and wants a plan that actually takes health seriously.",
    tagline:
      "Travel planning from the inside out. Built for travelers whose health isn't an afterthought - it's the starting point.",
    included: [
      'Medical travel readiness assessment (current condition vs destination risk)',
      'Destination health risk briefing (disease, altitude, heat, food safety, water quality)',
      'Prescription medication travel authorization documentation',
      'Controlled substance travel documentation (country-by-country)',
      'Travel health insurance specification (pre-existing conditions declared correctly)',
      'In-destination pharmacy and hospital mapping for your specific itinerary',
      'Emergency medical information card (multilingual, pharmacist-prepared)',
      'Vaccine status review and update suggestions',
    ],
    differentiators: [
      'Designed and delivered with input from a licensed pharmacist - not a Google search',
      'Controlled substance and prescription import rules per country (genuinely complex, genuinely dangerous to get wrong)',
      'The only travel package that treats your pre-existing conditions as a planning input, not a disclaimer',
    ],
    healthLabel: 'This IS the health package - full pharmacist layer',
    healthItems:
      "Complete medication review for travel suitability, controlled substance declaration letters (pharmacist-signed), country-specific OTC vs prescription drug status (e.g., common antihistamines are restricted in Japan), post-travel health monitoring brief, and traveler's diarrhea, altitude, malaria, and heat illness prevention protocols.",
    addons: [
      'Medevac insurance comparison brief',
      'Specialist referral in destination country (research only)',
      'Custom medication packing list with pharmacy alternatives',
      'Health condition-specific destination alternatives',
      'Medical translation card (your conditions in destination language)',
    ],
    geo: [
      {
        region: 'Traveling to Asia / SE Asia',
        items: [
          'Dengue, typhoid, hepatitis A/B vaccine review',
          'Heat and humidity management brief',
          'Counterfeit medication risk by country',
        ],
      },
      {
        region: 'Traveling to Africa / South America',
        items: [
          'Malaria prophylaxis planning (country-specific)',
          'Yellow fever certificate requirements',
          'High-altitude destination (e.g., Peru, Ethiopia) protocol',
        ],
      },
    ],
  },
  {
    slug: 'grand-circuit',
    name: 'The Grand Circuit',
    sub: 'Multi-region premium planning',
    icon: '◉',
    tone: 'circuit',
    target:
      'Experienced travelers or high-value clients planning a multi-region trip (e.g., Americas -> Europe -> North Africa -> Asia) who need coherent visa architecture, health continuity, and itinerary logic across multiple visa jurisdictions.',
    tagline:
      "For travelers who don't stay in one region. Visa logic, health coverage, and itinerary design that works across jurisdictions - without gaps, overlaps, or expensive mistakes.",
    included: [
      'Full multi-region visa architecture (all required visas mapped and timed)',
      'Passport validity and entry requirement check across all destinations',
      'Multi-jurisdiction health insurance review (coverage gaps between countries)',
      'Overland + multi-modal transport logic (trains, ferries, land borders)',
      '90/180-day Schengen management within the wider trip',
      'Currency and financial logistics brief per region',
      'Emergency contingency planning: what to do if a connection fails in Region 2',
      'Complete trip health brief spanning all destination health profiles',
    ],
    differentiators: [
      'Most travel services think in single trips - this is built for the arc of a whole journey',
      "Visa sequencing (which country's visa to apply for first, and why it matters)",
      'Health continuity across climate zones, altitude changes, and food environments',
    ],
    healthLabel: 'Multi-region health continuity plan included',
    healthItems:
      'Cross-region vaccine and prophylaxis planning (one vaccination strategy for all destinations), medication quantity planning across the full trip duration, region-transition health brief (e.g., moving from temperate Europe to tropical Southeast Asia), and multi-country medical emergency protocol.',
    addons: [
      'Luxury / boutique accommodation brief for each region',
      'Private guide recommendations',
      'Photography permit and restricted site access guidance',
      'Bespoke day-by-day itinerary (detailed)',
      'Pre-trip briefing call with the full Durian team',
    ],
    geo: [
      {
        region: 'Asian & African multi-region travelers',
        items: [
          "Multi-visa sequencing (which to apply for first, and why it matters)",
          'Non-EU origin financial proof across multiple currencies',
          'Home-country re-entry requirement tracking',
        ],
      },
      {
        region: 'Western outbound travelers',
        items: [
          'ETIAS + Schengen + non-EU visa stacking',
          'Visa-on-arrival vs pre-approval by region',
          'Travel advisory monitoring across regions',
        ],
      },
    ],
  },
];

const serviceSchema = packages.map((pkg) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: pkg.name,
  description: pkg.tagline,
  provider: {
    '@type': 'Organization',
    name: 'DURIAN Travel',
    url: 'https://www.duriantravel.com',
  },
  url: `https://www.duriantravel.com/services/#${pkg.slug}`,
  areaServed: ['Europe', 'North America', 'South America', 'Africa', 'Asia', 'Australia'],
}));

const breadcrumb = [{ name: 'Services', url: 'https://www.duriantravel.com/services/' }];
---

<BaseLayout
  title="Travel Packages for Schengen Strategy, First-Time Travel, and Health-Led Planning"
  description="Compare Durian Travel packages for Schengen applicants, first-time international travelers, families, refusal recoveries, health-led trips, digital nomads, and multi-region journeys."
  breadcrumb={breadcrumb}
  schema={serviceSchema}
  keywords="Durian Travel packages, Schengen strategy package, first-time international travel package, refusal reapplication support, travel wellness planning, family travel planning, digital nomad trip planning"
>
  <section class="hero-sm hero-gradient">
    <div class="container services-hero">
      <span class="section-label services-hero__label">Travel Packages</span>
      <h1 class="hero-sm__title services-hero__title">Choose the package that matches how you travel</h1>
      <p class="hero-sm__subtitle services-hero__subtitle">
        These packages replace the old single-service pages. Pick the track that fits your trip,
        your risk level, and your application complexity, then we will shape the support around that.
      </p>
      <div class="services-hero__actions">
        <a href="/free-visa-audit/" class="btn btn--primary">Start With a Free Audit</a>
        <a href="/contact/" class="btn btn--secondary">Send an Inquiry</a>
      </div>
      <p class="services-hero__note">
        We provide educational planning support. We do not submit visa applications on your behalf
        and we do not guarantee embassy outcomes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="notice notice--info mb-8">
        <span aria-hidden="true">📍</span>
        <p>
          <strong>Quick way to choose:</strong> start with <strong>Schengen Blueprint</strong> if
          your biggest stress is the visa file, <strong>First Journey</strong> if this is your first
          international trip, <strong>Recovery Route</strong> if you already have a refusal, and
          <strong>Wellness Journey</strong> if your health needs should shape the plan.
        </p>
      </div>

      <div class="package-picker">
        <div class="package-picker__header">
          <div>
            <span class="section-label">Choose a Package</span>
            <h2 class="package-picker__title">Compare all seven packages</h2>
          </div>
          <p class="package-picker__copy">
            Each option keeps the same Durian approach: strategy first, practical documents, and a
            route that still makes sense after the visa is approved.
          </p>
        </div>

        <div class="package-grid" role="tablist" aria-label="Durian Travel packages">
          {packages.map((pkg, index) => (
            <button
              id={`tab-${pkg.slug}`}
              class={`package-tab package-tab--${pkg.tone}`}
              type="button"
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={pkg.slug}
              tabindex={index === 0 ? '0' : '-1'}
              data-package-button={pkg.slug}
            >
              <span class="package-tab__name">{pkg.name}</span>
              <span class="package-tab__sub">{pkg.sub}</span>
            </button>
          ))}
        </div>

        <div class="package-panels">
          {packages.map((pkg, index) => (
            <section
              id={pkg.slug}
              class={`package-panel package-panel--${pkg.tone}`}
              role="tabpanel"
              aria-labelledby={`tab-${pkg.slug}`}
              data-package-panel={pkg.slug}
              hidden={index !== 0}
            >
              <div class="package-panel__header">
                <div class="package-panel__accent" aria-hidden="true">{pkg.icon}</div>
                <div>
                  <h3 class="package-panel__title">{pkg.name}</h3>
                  <p class="package-panel__tagline">{pkg.tagline}</p>
                </div>
              </div>

              <div class="package-panel__section">
                <span class="section-label">Ideal Client</span>
                <p class="package-panel__target">{pkg.target}</p>
              </div>

              <div class="package-health">
                <strong class="package-health__title">{pkg.healthLabel}</strong>
                <p class="package-health__copy">{pkg.healthItems}</p>
              </div>

              <div class="package-panel__columns">
                <div>
                  <span class="section-label">What&apos;s Included</span>
                  <div class="package-card">
                    {pkg.included.map((item) => <p class="package-item">{item}</p>)}
                  </div>
                </div>
                <div>
                  <span class="section-label">Unique Differentiators</span>
                  <div class="package-card package-card--spaced">
                    {pkg.differentiators.map((item) => <p class="package-item">{item}</p>)}
                  </div>
                  <span class="section-label">Optional Add-ons</span>
                  <div class="package-addon-row">
                    {pkg.addons.map((item) => <span class="package-addon">{item}</span>)}
                  </div>
                </div>
              </div>

              <div class="package-panel__section">
                <span class="section-label">Geo-Based Customization</span>
                <div class="package-geo-grid">
                  {pkg.geo.map((region) => (
                    <div class="package-geo-card">
                      <h4 class="package-geo-card__title">{region.region}</h4>
                      {region.items.map((item) => <p class="package-geo-card__item">{item}</p>)}
                    </div>
                  ))}
                </div>
              </div>

              <div class="package-panel__actions">
                <a href="/contact/" class="btn btn--primary">Ask About This Package</a>
                <a href="/free-visa-audit/" class="btn btn--secondary">Free Audit First</a>
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="container container--narrow">
      <header class="section-header text-center">
        <span class="section-label">How It Works</span>
        <h2 class="section-title">One package, then a tighter plan</h2>
      </header>
      <div class="services-steps">
        <div class="services-step">
          <span class="services-step__num">01</span>
          <h3 class="services-step__title">Choose your track</h3>
          <p class="services-step__copy">
            Pick the package that best matches your biggest source of risk or confusion.
          </p>
        </div>
        <div class="services-step">
          <span class="services-step__num">02</span>
          <h3 class="services-step__title">Send context</h3>
          <p class="services-step__copy">
            We review your passport context, route, documents, timeline, and any health or family
            constraints before shaping the work.
          </p>
        </div>
        <div class="services-step">
          <span class="services-step__num">03</span>
          <h3 class="services-step__title">Build the strongest version</h3>
          <p class="services-step__copy">
            The outcome is a clearer application, a cleaner itinerary, and fewer avoidable mistakes
            before money gets locked into the trip.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
  .hero-sm {
    padding-block: var(--space-16);
  }

  .services-hero {
    max-width: 72rem;
  }

  .services-hero__label {
    color: hsl(150 30% 82%);
  }

  .services-hero__title {
    color: var(--color-text-inverse);
    max-width: 14ch;
  }

  .services-hero__subtitle {
    color: hsl(150 25% 78%);
    max-width: 62ch;
  }

  .services-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .services-hero__note {
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: hsl(150 18% 80%);
    max-width: 60ch;
  }

  .package-picker {
    display: grid;
    gap: var(--space-8);
  }

  .package-picker__header {
    display: grid;
    gap: var(--space-4);
    align-items: end;
    grid-template-columns: 1.1fr 0.9fr;
  }

  .package-picker__title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
  }

  .package-picker__copy {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 44ch;
  }

  .package-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-3);
  }

  .package-tab {
    appearance: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
    background: var(--color-surface);
    color: var(--color-text);
    text-align: left;
    cursor: pointer;
    display: grid;
    gap: var(--space-1);
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .package-tab:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .package-tab:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--color-primary) 35%, transparent);
    outline-offset: 2px;
  }

  .package-tab[aria-selected='true'] {
    border-width: 2px;
    box-shadow: var(--shadow-md);
  }

  .package-tab--blueprint[aria-selected='true'] {
    border-color: var(--color-primary);
    background: var(--color-primary-bg);
  }

  .package-tab--journey[aria-selected='true'] {
    border-color: var(--color-warning);
    background: #fff7e8;
  }

  .package-tab--nomad[aria-selected='true'],
  .package-tab--family[aria-selected='true'],
  .package-tab--circuit[aria-selected='true'] {
    border-color: var(--color-primary-light);
    background: var(--color-bg-alt);
  }

  .package-tab--recovery[aria-selected='true'] {
    border-color: var(--color-error);
    background: #fff0f0;
  }

  .package-tab--wellness[aria-selected='true'] {
    border-color: var(--color-success);
    background: #eef9f3;
  }

  .package-tab__name {
