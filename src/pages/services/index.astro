<script>
  const buttons = Array.from(document.querySelectorAll('[data-package-button]'));
  const panels = Array.from(document.querySelectorAll('[data-package-panel]'));

  function getValidSlug(slug) {
    return buttons.some((button) => button.dataset.packageButton === slug)
      ? slug
      : buttons[0]?.dataset.packageButton;
  }

  function activatePackage(slug, shouldUpdateHash = true, shouldFocus = shouldUpdateHash) {
    const nextSlug = getValidSlug(slug);
    if (!nextSlug) return;

    buttons.forEach((button) => {
      const isActive = button.dataset.packageButton === nextSlug;
      button.setAttribute('aria-selected', String(isActive));
      button.setAttribute('tabindex', isActive ? '0' : '-1');
      if (isActive && shouldFocus) button.focus({ preventScroll: true });
    });

    panels.forEach((panel) => {
      panel.hidden = panel.dataset.packagePanel !== nextSlug;
    });

    if (shouldUpdateHash && window.location.hash !== `#${nextSlug}`) {
      window.history.replaceState(null, '', `#${nextSlug}`);
    }
  }

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      activatePackage(button.dataset.packageButton);
    });
  });

  window.addEventListener('hashchange', () => {
    activatePackage(window.location.hash.replace('#', ''), false, false);
  });

  activatePackage(window.location.hash.replace('#', ''), false, false);
</script>
