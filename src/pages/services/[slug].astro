---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABanner from '../../components/CTABanner.astro';
import { servicePackages, servicePackageBySlug, servicePositioning } from '../../data/service-pages';

export async function getStaticPaths() {
  return servicePackages.map((pkg) => ({
    params: { slug: pkg.url_slug },
    props: { pkg },
  }));
}

const { pkg = servicePackageBySlug[Astro.params.slug ?? ''] } = Astro.props;

const canonical = `https://www.duriantravel.com${pkg.href}`;
const breadcrumb = [
  { name: 'Services', url: 'https://www.duriantravel.com/services/' },
  { name: pkg.name, url: canonical },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: pkg.name,
  description: pkg.tagline,
  provider: {
    '@type': 'Organization',
    name: 'DURIAN Travel',
    url: 'https://www.duriantravel.com',
  },
  url: canonical,
  areaServed: ['Europe', 'North America', 'South America', 'Africa', 'Asia', 'Australia'],
  audience: {
    '@type': 'Audience',
    audienceType: pkg.target,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pkg.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={pkg.metaTitle}
  description={pkg.metaDescription}
  canonical={canonical}
  breadcrumb={breadcrumb}
  schema={[serviceSchema, faqSchema]}
  keywords={pkg.seo_keywords.join(', ')}
>
  <div class="container">
    <Breadcrumb items={[{ name: 'Services', href: '/services/' }, { name: pkg.name }]} />
  </div>

  <section class={`service-hero service-hero--${pkg.tone}`}>
    <div class="container service-hero__inner">
      <div class="service-hero__meta">
        <span class="service-chip">{pkg.tier}</span>
        <span class="service-chip service-chip--soft">{pkg.name}</span>
      </div>
      <div class="service-hero__icon" aria-hidden="true">{pkg.icon}</div>
      <h1 class="service-hero__title">{pkg.h1}</h1>
      <p class="service-hero__subtitle">{pkg.tagline}</p>
      <p class="service-hero__positioning">{servicePositioning}</p>
      <div class="service-hero__actions">
        <a href="/contact/" class="btn btn--primary">Send Us Your Situation</a>
        <a href="/free-visa-audit/" class="btn btn--secondary">Start With a Free Audit</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container service-layout">
      <article class="service-main">
        <section class="service-section">
          <span class="section-label">Who This Is For</span>
          <p class="service-target">{pkg.target}</p>
          <div class="persona-grid">
            {pkg.personas.map((persona) => (
              <div class="persona-card">
                <p>{persona}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="service-section">
          <span class="section-label">What's Included</span>
          <div class="service-card">
            <ul class="service-list">
              {pkg.included.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>

        <section class="service-section">
          <span class="section-label">Why This Package Is Different</span>
          <div class="service-card">
            <ul class="service-list service-list--check">
              {pkg.differentiators.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>

        <section class="service-health">
          <div class="service-health__heading">
            <span class="service-health__credential">{pkg.health_layer.credential}</span>
            <div>
              <span class="section-label">The Health Layer</span>
              <h2 class="service-health__title">{pkg.health_layer.label}</h2>
            </div>
          </div>
          <div class="service-card">
            <ul class="service-list">
              {pkg.health_layer.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>

        <section class="service-section">
          <span class="section-label">Geo-Based Customization</span>
          <div class="geo-grid">
            {pkg.geo_customization.map((segment) => (
              <div class="geo-card">
                <h2 class="geo-card__title">{segment.segment}</h2>
                <ul class="service-list">
                  {segment.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </section>

        <section class="service-section">
          <span class="section-label">FAQ</span>
          <div class="faq-list">
            {pkg.faq.map((item) => (
              <details class="faq-item">
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      </article>

      <aside class="service-sidebar">
        <div class="service-card service-card--sticky">
          <span class="section-label">SEO Targets</span>
          <div class="keyword-row">
            {pkg.seo_keywords.map((keyword) => <span class="keyword-pill">{keyword}</span>)}
          </div>
        </div>

        <div class="service-card">
          <span class="section-label">Optional Add-ons</span>
          <div class="addon-row">
            {pkg.addons.map((item) => <span class="addon-pill">{item}</span>)}
          </div>
        </div>

        <div class="service-note">
          <strong>How to use this page:</strong> if the situation described here sounds like your real bottleneck, this is the right package. If you are still unsure, the free audit is the faster first step.
        </div>

        <div class="service-actions">
          <a href="/contact/" class="btn btn--primary btn--block">Ask About This Package</a>
          <a href="/services/" class="btn btn--secondary btn--block">Compare All Packages</a>
        </div>
      </aside>
    </div>
  </section>

  <CTABanner />
</BaseLayout>

<style>
.service-hero {
  padding-block: var(--space-16);
  color: white;
  background:
    radial-gradient(circle at top right, rgb(196 75 54 / 0.3), transparent 34%),
    linear-gradient(160deg, #0f2138 0%, #182f4d 100%);
}

.service-hero__inner {
  max-width: 56rem;
}

.service-hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}

.service-chip {
  border: 1px solid rgb(255 255 255 / 0.2);
  border-radius: var(--radius-full);
  padding: 0.35rem 0.85rem;
  font-size: var(--text-xs);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.service-chip--soft {
  background: rgb(255 255 255 / 0.08);
}

.service-hero__icon {
  font-size: 2.5rem;
  margin-bottom: var(--space-4);
}

.service-hero__title {
  font-size: clamp(var(--text-3xl), 4.5vw, 4rem);
  line-height: 1.1;
  margin-bottom: var(--space-4);
}

.service-hero__subtitle {
  font-size: var(--text-xl);
  max-width: 40rem;
  color: rgb(255 255 255 / 0.85);
  margin-bottom: var(--space-5);
}

.service-hero__positioning {
  max-width: 42rem;
  color: hsl(150 30% 75%);
}

.service-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-top: var(--space-8);
}

.service-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
  gap: var(--space-10);
  align-items: start;
}

.service-main,
.service-sidebar {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.service-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.service-target {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: var(--leading-relaxed);
}

.service-card {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  box-shadow: 0 10px 30px rgb(15 33 56 / 0.05);
}

.service-card--sticky {
  position: sticky;
  top: calc(64px + var(--space-4));
}

.persona-grid,
.geo-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: var(--space-4);
}

.persona-card,
.geo-card {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
}

.geo-card__title,
.service-health__title {
  margin: 0;
}

.service-list {
  margin: 0;
  padding-left: 1.1rem;
  display: grid;
  gap: var(--space-3);
}

.service-list--check li::marker {
  content: '• ';
  color: var(--color-accent);
}

.service-health {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.service-health__heading {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.service-health__credential {
  width: 3rem;
  height: 3rem;
  border-radius: var(--radius-full);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: white;
  font-weight: var(--font-bold);
}

.keyword-row,
.addon-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

.keyword-pill,
.addon-pill {
  border-radius: var(--radius-full);
  padding: 0.45rem 0.85rem;
  font-size: var(--text-sm);
}

.keyword-pill {
  background: rgb(15 33 56 / 0.08);
  color: var(--color-navy);
}

.addon-pill {
  background: rgb(196 75 54 / 0.1);
  color: var(--color-primary);
}

.faq-list {
  display: grid;
  gap: var(--space-4);
}

.faq-item {
  background: white;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
}

.faq-item summary {
  cursor: pointer;
  font-weight: var(--font-semibold);
}

.faq-item p {
  margin-top: var(--space-3);
  color: var(--color-text-muted);
}

.service-note {
  background: rgb(15 33 56 / 0.06);
  border-radius: var(--radius-xl);
  padding: var(--space-5);
  color: var(--color-text-muted);
}

.service-actions {
  display: grid;
  gap: var(--space-3);
}

.btn--block {
  display: inline-flex;
  justify-content: center;
  width: 100%;
}

@media (max-width: 900px) {
  .service-layout {
    grid-template-columns: 1fr;
  }

  .service-card--sticky {
    position: static;
  }
}
</style>
