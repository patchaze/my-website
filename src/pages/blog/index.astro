---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BlogCard from '../../components/BlogCard.astro';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Visa Application Strategy Blog — Tips, Guides & Insights"
  description="Visa strategy blog: guides on documents, cover letters, financial proof, and refusal analysis."
  breadcrumb={[{ name: 'Blog', url: 'https://www.duriantravel.com/blog/' }]}
>
  <section class="hero-sm hero-gradient">
    <div class="container relative">
      <span class="section-label" style="color:var(--color-accent-light)">Insights & Education</span>
      <h1 class="hero-sm__title" style="color:white">Visa Strategy Blog</h1>
      <p class="hero-sm__subtitle" style="color:hsl(150 30% 75%); max-width:60ch; line-height:var(--leading-relaxed); font-size:var(--text-lg)">
        Evidence-based guidance on visa document preparation, financial proof,
        cover letter strategy, and refusal analysis. All content cites official sources.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {allPosts.length === 0 ? (
        <p class="text-muted text-center">No posts published yet. Check back soon.</p>
      ) : (
        <div class="grid-3">
          {allPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate.toISOString()}
              tags={post.data.tags}
              readTime={post.data.readTime}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
.hero-sm { padding-block: var(--space-16); }
.hero-sm__title { font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl)); margin-bottom: var(--space-4); }
</style>
